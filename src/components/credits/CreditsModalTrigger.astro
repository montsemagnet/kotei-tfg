---
import TitleIconTrigger from "@/components/fundations/elements/TitleIconTrigger.astro";

interface Props {
  modalId: string;
  label: string;
}

const { modalId, label } = Astro.props;
---

<TitleIconTrigger
  titleVariant="textLG"
  titleClass="leading-snug"
  data-credits-modal-target={modalId}
  aria-haspopup="dialog"
  aria-label={`Obrir: ${label}`}
>
  {label}
</TitleIconTrigger>
