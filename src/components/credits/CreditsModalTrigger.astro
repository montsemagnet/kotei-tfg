---
import Text from "@/components/fundations/elements/Text.astro";

interface Props {
  modalId: string;
  label: string;
}

const { modalId, label } = Astro.props;
---

<button
  type="button"
  data-credits-modal-target={modalId}
  class="text-left cursor-pointer group flex flex-wrap items-center gap-2 w-full"
  aria-haspopup="dialog"
  aria-label={`Obrir: ${label}`}
>
  <Text
    tag="span"
    variant="textLG"
    class="font-medium text-accent-700 dark:text-accent-400 underline decoration-accent-700/30 dark:decoration-accent-400/40 underline-offset-[6px] group-hover:decoration-accent-700 dark:group-hover:decoration-accent-400 transition-colors leading-snug"
  >
    {label}
  </Text>
  <span
    class="inline-flex size-7 shrink-0 items-center justify-center rounded-full border border-accent-700/25 dark:border-accent-400/30 text-accent-700 dark:text-accent-400 text-sm leading-none group-hover:bg-accent-700/10 dark:group-hover:bg-accent-400/10 transition-colors"
    aria-hidden="true"
  >
    +
  </span>
</button>
