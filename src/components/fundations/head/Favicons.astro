---
import { withBase } from "@/utils/withBase";
const v = "?v=1";
---

<link rel="icon" href={withBase(`/favicon.ico${v}`)} sizes="any" />
<link rel="icon" href={withBase(`/favicon.png${v}`)} type="image/png" />
<link rel="icon" type="image/png" sizes="16x16" href={withBase(`/favicon-16x16.png${v}`)} />
<link rel="icon" type="image/png" sizes="32x32" href={withBase(`/favicon-32x32.png${v}`)} />
<link rel="icon" type="image/png" sizes="48x48" href={withBase(`/favicon-48x48.png${v}`)} />
<link rel="apple-touch-icon" sizes="180x180" href={withBase(`/apple-touch-icon.png${v}`)} />
