---
import { AstroSeo } from "@lexingtonthemes/seo";
import { project } from "@/data/project";

const siteUrl = Astro.site?.href ?? "https://jazzy-pegasus-731767.netlify.app/";
---

<AstroSeo
  title={project.title}
  description={project.subtitle}
  canonical={siteUrl}
  openGraph={{
    url: siteUrl,
    title: project.title,
    description: project.subtitle,
    site_name: project.title,
    type: "website",
    locale: "ca_ES",
  }}
  twitter={{
    cardType: "summary",
  }}
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={siteUrl} />
<meta property="og:title" content={project.title} />
<meta property="og:description" content={project.subtitle} />

<!-- Twitter -->
<meta property="twitter:card" content="summary" />
<meta property="twitter:url" content={siteUrl} />
<meta property="twitter:title" content={project.title} />
<meta property="twitter:description" content={project.subtitle} />

<!-- Canonical URL -->
<link rel="canonical" href={siteUrl} />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />
