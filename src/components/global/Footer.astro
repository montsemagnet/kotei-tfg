---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { project, teamMembers } from "@/data/project";
import { withBase } from "@/utils/withBase";

const footerLinks = [
  { href: "/", text: "Inici" },
  { href: "/itineraris", text: "Itineraris" },
  { href: "/termes", text: "Glossari de termes" },
  { href: "/credits", text: "Crèdits i llicències" },
];

const lastUpdated = new Date().toLocaleDateString("ca-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<footer class="bg-base-50 dark:bg-base-800 overflow-hidden border-t border-base-200 dark:border-base-700">
  <Wrapper variant="standard" class="py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-8">
      <div>
        <Text
          tag="h2"
          variant="textBase"
          class="font-medium text-base-900 dark:text-white"
        >
          {project.title}
        </Text>
        <Text
          tag="p"
          variant="textSM"
          class="mt-2 text-base-600 dark:text-base-400 leading-relaxed"
        >
          {project.institution}
          <br />
          {project.faculty}
        </Text>
        <Text
          tag="p"
          variant="textXS"
          class="mt-4 text-base-500 dark:text-base-500 uppercase tracking-wide"
        >
          Darrera actualització: {lastUpdated}
        </Text>
      </div>

      <div>
        <Text
          tag="h3"
          variant="textSM"
          class="font-medium uppercase tracking-wide text-base-900 dark:text-white"
        >
          Equip
        </Text>
        <ul class="mt-3 space-y-3">
          {
            teamMembers.map((member) => (
              <li>
                <Text
                  tag="p"
                  variant="textSM"
                  class="text-base-900 dark:text-white font-medium"
                >
                  {member.name}
                </Text>
                <Text
                  tag="p"
                  variant="textXS"
                  class="text-base-500 dark:text-base-400 mt-0.5"
                >
                  {member.roles.join(" · ")}
                </Text>
                <a
                  href={`mailto:${member.email}`}
                  class="text-sm text-base-600 dark:text-base-400 hover:text-accent-500 dark:hover:text-accent-300 duration-300"
                >
                  {member.email}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <Text
          tag="h3"
          variant="textSM"
          class="font-medium uppercase tracking-wide text-base-900 dark:text-white"
        >
          Enllaços
        </Text>
        <ul class="mt-3 space-y-2">
          {
            footerLinks.map((link) => (
              <li>
                <a
                  href={withBase(link.href)}
                  class="text-sm text-base-600 dark:text-base-400 hover:text-accent-500 dark:hover:text-accent-300 duration-300"
                >
                  {link.text}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href="https://www.uvic.cat/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-base-600 dark:text-base-400 hover:text-accent-500 dark:hover:text-accent-300 duration-300"
            >
              UVic-UCC
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-10 pt-8 border-t border-base-200 dark:border-base-700 space-y-3"
    >
      <Text tag="p" variant="textSM" class="text-base-700 dark:text-base-400">
        © {project.publicationYear} Montserrat Magnet Sabata. Treball de Final de
        Grau — Grau en Biologia. Tots els drets reservats.
      </Text>
      <Text tag="p" variant="textXS" class="text-base-500 dark:text-base-500 leading-relaxed">
        Prohibida la reproducció, difusió o publicació total o parcial d'aquest
        lloc (textos, imatges, dades de camp, materials petrogràfics i recursos
        associats) sense autorització expressa i per escrit de l'autora i les
        tutores.
      </Text>
    </div>
  </Wrapper>
</footer>
