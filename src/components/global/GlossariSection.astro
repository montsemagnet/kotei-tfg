---
import Text from "@/components/fundations/elements/Text.astro";
import TitleIconTrigger from "@/components/fundations/elements/TitleIconTrigger.astro";
import { withBase } from "@/utils/withBase";

interface Props {
  class?: string;
  description?: string;
  /** Variant del text descriptiu (p. ex. textXL a parades) */
  descriptionVariant?: "textLG" | "textXL";
  /** Dins del bloc de menús (Geologia, Paleogeologia…): mateixa fila amb border-b */
  menuRow?: boolean;
  /** Carta PDF de l'ICGC sota «Glossari» (pàgina principal i itinerari) */
  showCartaPdf?: boolean;
}

const {
  class: className,
  description = "Definicions dels termes geològics utilitzats a la Web.",
  descriptionVariant = "textLG",
  menuRow = false,
  showCartaPdf = false,
} = Astro.props;

const href = withBase("/termes");
const cartaPdfHref =
  "https://datacloud.icgc.cat/datacloud/descarregues-web/bd/pubs/ChronostratChart2023-09Catalan.pdf";
const rowClass =
  "grid grid-cols-1 lg:grid-cols-4 items-start gap-x-6 gap-y-2 py-4";
const bodyTextLayout = "lg:col-span-3 min-w-0 leading-relaxed";
const bodyTextClass =
  descriptionVariant === "textXL"
    ? `${bodyTextLayout} text-base-500 dark:text-base-400`
    : `${bodyTextLayout} text-base-700 dark:text-base-400`;
---

<div
  data-aos="fade-up"
  data-aos-duration="1000"
  class:list={[
    menuRow
      ? "border-b border-base-200 dark:border-base-800"
      : "border-t border-base-200 dark:border-base-800",
    className,
  ]}
>
  <div class={rowClass}>
    <div class="min-w-0">
      <TitleIconTrigger as="a" href={href}>
        Glossari
      </TitleIconTrigger>
    </div>
    <Text tag="p" variant={descriptionVariant} class={bodyTextClass}>
      {description}
    </Text>
  </div>

  {
    showCartaPdf && (
      <div
        class:list={[
          rowClass,
          "border-t border-base-200 dark:border-base-800",
        ]}
      >
        <div class="min-w-0">
          <TitleIconTrigger
            as="a"
            href={cartaPdfHref}
            target="_blank"
            rel="noopener noreferrer"
          >
            Escala del temps geològic
          </TitleIconTrigger>
        </div>
        <Text tag="p" variant="textLG" class={bodyTextClass}>
          Carta oficial de l'ICGC amb la jerarquia d'unitats
          cronostratigràfiques (eons, eres, períodes, èpoques) i les edats en
          Ma, adaptada de la Comissió Internacional d'Estratigrafia (ICS).
        </Text>
      </div>
    )
  }
</div>
