---
// Importa els logos amb noms diferents
import logoUvicBN from "@/images/brands/logo_bn_uvic.png";
import logoUvicP from "@/images/brands/uvic-p.png";

// Assets
import Logo from "@/components/assets/Logo.astro";
import ThemeToggle from "@/components/assets/ThemeToggle.astro";
// Components
import Search from "@/components/global/Search.astro";
import LanguageSelector from "@/components/global/LanguageSelector.astro";
---

<a
  href="https://www.uvic.cat/grau/biologia"
  target="_blank"
  rel="noopener noreferrer"
  class="fixed top-8 left-8 z-[100]"
  aria-label="Grau de Biologia — UVic"
>
  <img src={logoUvicBN.src} alt="Logo UVic B&N" class="logo-nav" />
</a>

<div class="fixed bottom-8 left-0 right-0 flex justify-center z-[100] pointer-events-none">
  <div
    class="pointer-events-auto bg-base-900 dark:bg-base-100 rounded-(--card-radius) p-(--card-padding) group [--card-padding:--spacing(1)] [--card-radius:var(--radius-lg)] max-w-2xl w-auto"
  >
    <div class="flex items-center justify-between p-0.5 gap-1">
      <div
        class="flex items-center justify-center size-14 bg-base-800 dark:bg-base-50 rounded-[calc(var(--card-radius)-var(--card-padding))]"
      >
        <a href="/" aria-label="Go to homepage">
          <span class="sr-only">Go to homepage</span>
          <Logo class="h-6 text-white dark:text-base-900" />
        </a>
      </div>

      <a href="/system/overview" class="px-2 py-1 h-14 text-sm flex bg-base-800 dark:bg-base-50 items-center outline outline-base-900 dark:outline-base-100 dark:text-base-900 hover:bg-base-950 duration-300 rounded-[calc(var(--card-radius)-var(--card-padding))] text-white dark:hover:bg-base-300">Overview</a>
      <a href="/itineraris" class="px-2 py-1 h-14 text-sm flex bg-base-800 dark:bg-base-50 items-center outline outline-base-900 dark:outline-base-100 dark:text-base-900 hover:bg-base-950 duration-300 rounded-[calc(var(--card-radius)-var(--card-padding))] text-white dark:hover:bg-base-300">Itineraris</a>

      <LanguageSelector />

      <ThemeToggle class="px-2 py-1 size-14 flex bg-base-800 dark:bg-base-50 items-center outline outline-base-900 dark:outline-base-100 dark:text-base-900 hover:bg-base-950 duration-300 rounded-[calc(var(--card-radius)-var(--card-padding))] text-white dark:hover:bg-base-300" />
      
      <Search />

      <a
        href="https://www.uvic.cat/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Universitat de Vic — obre en una pestanya nova"
        class="px-2 py-1 h-14 flex items-center bg-base-50 outline outline-base-900 dark:outline-base-100 hover:bg-base-950 duration-300 rounded-[calc(var(--card-radius)-var(--card-padding))] dark:bg-base-900 dark:hover:bg-base-800"
      >
        <img src={logoUvicP.src} alt="Logo UVic P" class="h-6 w-auto" />
      </a>
    </div>
  </div>
</div>

<style>
  .logo-nav {
    width: 200px;
    height: auto;
    display: block;
    transition: opacity 0.3s ease;
  }
  .logo-nav:hover {
    opacity: 0.7;
  }
</style>