---
// Assets
import { Image } from "astro:assets";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";

const { index, variant = "default", hideImage = false, layout = "stack" } = Astro.props;
const isFeatured = variant === "featured";
const isInlineFeatured = isFeatured && layout === "inline";
const enConstruccio = Astro.props.post.data.enConstruccio ?? false;
const { title, url, description, thumbnail } = {
  url: "/itineraris/" + Astro.props.post.id,
  title: Astro.props.post.data.title,
  description: Astro.props.post.data.description,
  thumbnail: Astro.props.post.data.thumbnail.url,
};
---

<div class:list={[
  "relative overflow-hidden",
  !enConstruccio && "group",
  isInlineFeatured && "flex w-full flex-col gap-4 sm:flex-row sm:items-start sm:gap-6",
  isFeatured && !hideImage && !isInlineFeatured && "lg:grid lg:grid-cols-2 lg:gap-10 lg:items-center",
  isFeatured && hideImage && "relative z-0 w-full",
]}>
  {
    !enConstruccio && (
      <a class="absolute inset-0 z-10" href={url} title={title} aria-hidden="true" tabindex="-1" />
    )
  }
  {
    !hideImage && (
      <div class:list={[
        "relative overflow-hidden",
        isInlineFeatured && "w-full shrink-0 sm:w-40 lg:w-44",
      ]}>
        <Image
          src={thumbnail}
          alt={title}
          width={1000}
          height={isInlineFeatured ? 560 : isFeatured ? 400 : 100}
          class:list={[
            "w-full object-cover object-center",
            isInlineFeatured ? "aspect-[3/4]" : isFeatured ? "aspect-[21/9]" : "",
            enConstruccio && "opacity-60",
          ]}
        />
      </div>
    )
  }

  <div class:list={[
    "relative z-20",
    "mt-3",
    isFeatured && !hideImage && !isInlineFeatured && "lg:mt-0",
    (hideImage || isInlineFeatured) && "mt-0",
    isInlineFeatured && "min-w-0 flex-1",
  ]}>
    <Text
      tag="h3"
      variant={isFeatured && hideImage ? "textBase" : isFeatured ? "displaySM" : "textBase"}
      class:list={[
        "text-base-900 dark:text-white font-medium",
        isFeatured && hideImage
          ? "lg:whitespace-nowrap tracking-tight leading-snug"
          : isFeatured
            ? "tracking-tighter leading-tight"
            : "leading-6",
      ]}
    >
      (0{index}) {title}
    </Text>

    <Text
      tag="p"
      variant={isFeatured ? "textLG" : "textSM"}
      class:list={[
        "mt-2 text-base-500 dark:text-base-400",
        !isFeatured && "line-clamp-3",
      ]}
    >
      {description}
    </Text>

    {
      enConstruccio ? (
        <Text
          tag="p"
          variant="textSM"
          class="mt-2 text-base-400 dark:text-base-500 italic"
        >
          En construcció
        </Text>
      ) : (
        <div class="group relative inline-flex overflow-hidden w-full text-base-700 dark:text-base-400 mt-2">
          <div class="translate-y-0 transition group-hover:-translate-y-[150%] duration-500">
            <Text tag="p" variant="textSM">Veure itinerari</Text>
          </div>
          <div class="absolute flex items-center w-full justify-between translate-y-[150%] transition group-hover:translate-y-0 duration-500">
            <Text tag="p" variant="textSM">Veure itinerari</Text>
            <span>&rarr;</span>
          </div>
        </div>
      )
    }
  </div>
</div>
