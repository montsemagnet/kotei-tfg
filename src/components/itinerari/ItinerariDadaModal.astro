---
import { Image } from "astro:assets";
import Text from "@/components/fundations/elements/Text.astro";
import ItinerariZoom from "@/components/itinerari/ItinerariZoom.astro";
import ItinerariModalEmbed from "@/components/itinerari/ItinerariModalEmbed.astro";
import ItinerariModalHeaderActions from "@/components/itinerari/ItinerariModalHeaderActions.astro";
import ItinerariModalPublicMedia from "@/components/itinerari/ItinerariModalPublicMedia.astro";
import { withBase } from "@/utils/withBase";

interface Subsection {
  title: string;
  paragraphs: string[];
  media?: PublicMedia & { title?: string };
}

interface SectionTable {
  caption?: string;
  headers: string[];
  rows: { cells: string[] }[];
}

interface Section {
  title: string;
  paragraphs?: string[];
  subsections?: Subsection[];
  media?: PublicMedia & { title?: string };
  mediaItems?: (PublicMedia & { title?: string })[];
  mediaCaption?: string;
  mediaTitle?: string;
  mediaAfterParagraph?: number;
  mediaAfterSubsection?: number;
  mediaBeforeSubsection?: {
    subsectionIndex: number;
    title?: string;
    items: (PublicMedia & { title?: string })[];
    caption?: string;
  };
  table?: SectionTable;
  paragraphsAfter?: string[];
  embed?: {
    title?: string;
    iframeTitle: string;
    src: string;
    caption?: string;
    link?: string;
    linkLabel?: string;
  };
}

interface StaticImage {
  url: ImageMetadata;
  alt: string;
  caption?: string;
}

interface PublicMedia {
  publicSrc: string;
  alt: string;
  caption?: string;
  tipus?: "animacio" | "video";
}

type ModalImage = StaticImage | PublicMedia;

function isPublicMedia(image: ModalImage): image is PublicMedia {
  return "publicSrc" in image;
}

interface Props {
  modalId: string;
  label: string;
  intro?: string;
  introMedia?: PublicMedia & { title: string; caption?: string };
  sections: Section[];
  images?: ModalImage[];
  /** Focus trap i retorn de focus al botó d'obertura */
  focusTrap?: boolean;
  /** Botons A− / A+ per escalar el text */
  textSizeControls?: boolean;
}

const {
  modalId,
  label,
  intro,
  introMedia,
  sections,
  images = [],
  focusTrap = true,
  textSizeControls = true,
} = Astro.props;
const titleId = `${modalId}-title`;
const zoomId = `${modalId}-zoom`;
const textContentClass = textSizeControls ? "itinerari-modal-text-content" : "";
const titlePaddingClass = textSizeControls ? "pr-52" : "pr-24";
const zoomThumbClass =
  "w-full cursor-pointer overflow-hidden border-0 p-0 bg-transparent hover:opacity-90 transition-opacity";
const zoomImageClass =
  "w-full h-auto rounded-md border border-base-200 dark:border-base-800";
const figureCaptionClass =
  "mt-2 text-sm text-base-500 dark:text-base-400 leading-relaxed";
const figureTitleClass =
  "dark:text-white text-base-900 font-medium mb-3 leading-snug";
const panelCloseClass =
  "itinerari-dada-close rounded-full bg-base-200 dark:bg-base-800 px-4 py-2 text-sm text-base-900 dark:text-white hover:bg-base-300 dark:hover:bg-base-700";
---

<dialog
  id={modalId}
  class="itinerari-dada-dialog fixed inset-0 z-[110] m-0 size-full max-h-none max-w-none border-0 bg-base-950/90 p-4 backdrop:bg-transparent open:flex open:items-start open:justify-center overflow-y-auto"
  aria-modal={focusTrap ? "true" : undefined}
  aria-labelledby={focusTrap ? titleId : undefined}
  data-focus-trap={focusTrap ? "true" : "false"}
>
  <div
    class="itinerari-dada-panel relative my-8 w-full max-w-3xl rounded-lg bg-base-100 dark:bg-base-900 p-6 lg:p-10 shadow-xl"
    data-text-size-enabled={textSizeControls ? "true" : undefined}
  >
    <ItinerariModalHeaderActions
      closeClass={panelCloseClass}
      showTextSize={textSizeControls}
    />

    <div class={textContentClass}>
      <Text
        id={titleId}
        tag="h2"
        variant="displayMD"
        class={`dark:text-white text-base-900 font-medium tracking-tighter mb-6 capitalize ${titlePaddingClass}`}
      >
        {label}
      </Text>

      {
        intro && (
          <Text
            tag="p"
            variant="textXL"
            class="text-base-600 dark:text-base-300 mb-8 leading-relaxed"
          >
            {intro}
          </Text>
        )
      }
    </div>

    {
      introMedia && (
        <ItinerariModalPublicMedia
          media={introMedia}
          zoomId={`${zoomId}-intro`}
          class="mb-10"
        />
      )
    }

    <div class="flex flex-col gap-8">
      {
        sections.map((section, sectionIndex) => (
          <div>
            <div class={textContentClass}>
              <Text
                tag="h3"
                variant="displaySM"
                class="dark:text-white text-base-900 font-medium mb-3"
              >
                {section.title}
              </Text>
              {section.paragraphs?.map((paragraph, paragraphIndex) => (
                <>
                  <Text
                    tag="p"
                    variant="textBase"
                    class="text-base-500 dark:text-base-400 mb-3 leading-relaxed last:mb-0"
                  >
                    {paragraph}
                  </Text>
                  {
                    section.media &&
                    section.mediaAfterParagraph === paragraphIndex && (
                      <ItinerariModalPublicMedia
                        media={section.media}
                        zoomId={`${zoomId}-section-${sectionIndex}-inline`}
                      />
                    )
                  }
                </>
              ))}
              {
                section.mediaItems &&
                !section.subsections?.length &&
                section.mediaAfterSubsection === undefined && (
                  <div class="my-6 flex flex-col gap-6">
                    {
                      section.mediaTitle && (
                        <Text
                          tag="h4"
                          variant="textBase"
                          class={figureTitleClass}
                        >
                          {section.mediaTitle}
                        </Text>
                      )
                    }
                    {section.mediaItems.map((item, itemIndex) => (
                      <ItinerariModalPublicMedia
                        media={item}
                        zoomId={`${zoomId}-section-${sectionIndex}-items-${itemIndex}`}
                        class="my-0"
                      />
                    ))}
                    {
                      section.mediaCaption && (
                        <figcaption class={figureCaptionClass}>
                          {section.mediaCaption}
                        </figcaption>
                      )
                    }
                  </div>
                )
              }
              {
                section.subsections?.map((subsection, subsectionIndex) => (
                  <>
                    {
                      section.mediaBeforeSubsection &&
                      section.mediaBeforeSubsection.subsectionIndex === subsectionIndex && (
                        <div class="my-6 flex flex-col gap-4">
                          {
                            section.mediaBeforeSubsection.title && (
                              <Text
                                tag="h4"
                                variant="textBase"
                                class={figureTitleClass}
                              >
                                {section.mediaBeforeSubsection.title}
                              </Text>
                            )
                          }
                          {section.mediaBeforeSubsection.items.map((item, itemIndex) => (
                            <ItinerariModalPublicMedia
                              media={item}
                              zoomId={`${zoomId}-section-${sectionIndex}-before-${itemIndex}`}
                              class="my-0"
                            />
                          ))}
                          {
                            section.mediaBeforeSubsection.caption && (
                              <figcaption class={figureCaptionClass}>
                                {section.mediaBeforeSubsection.caption}
                              </figcaption>
                            )
                          }
                        </div>
                      )
                    }
                    <div class="mt-4 mb-2">
                      <Text
                        tag="h4"
                        variant="textBase"
                        class="dark:text-white text-base-900 font-medium mb-2 leading-snug"
                      >
                        {subsection.title}
                      </Text>
                      {subsection.paragraphs.map((paragraph) => (
                        <Text
                          tag="p"
                          variant="textBase"
                          class="text-base-500 dark:text-base-400 mb-3 leading-relaxed last:mb-0"
                        >
                          {paragraph}
                        </Text>
                      ))}
                    </div>
                    {
                      subsection.media && (
                        <ItinerariModalPublicMedia
                          media={subsection.media}
                          zoomId={`${zoomId}-section-${sectionIndex}-subsection-${subsectionIndex}`}
                          class="my-6"
                        />
                      )
                    }
                    {
                      section.mediaItems &&
                      section.mediaAfterSubsection === subsectionIndex && (
                        <div class="my-6 flex flex-col gap-4">
                          {
                            section.mediaTitle && (
                              <Text
                                tag="h4"
                                variant="textBase"
                                class={figureTitleClass}
                              >
                                {section.mediaTitle}
                              </Text>
                            )
                          }
                          {section.mediaItems.map((item, itemIndex) => (
                            <ItinerariModalPublicMedia
                              media={item}
                              zoomId={`${zoomId}-section-${sectionIndex}-items-${itemIndex}`}
                              class="my-0"
                            />
                          ))}
                          {
                            section.mediaCaption && (
                              <figcaption class={figureCaptionClass}>
                                {section.mediaCaption}
                              </figcaption>
                            )
                          }
                        </div>
                      )
                    }
                  </>
                ))
              }
              {
                section.paragraphsAfter?.map((paragraph) => (
                  <Text
                    tag="p"
                    variant="textBase"
                    class="text-base-500 dark:text-base-400 mb-3 leading-relaxed last:mb-0"
                  >
                    {paragraph}
                  </Text>
                ))
              }
              {
                section.table && (
                  <div class="mt-4 overflow-x-auto">
                    {
                      section.table.caption && (
                        <Text
                          tag="p"
                          variant="textBase"
                          class="text-base-500 dark:text-base-400 mb-3 leading-relaxed"
                        >
                          {section.table.caption}
                        </Text>
                      )
                    }
                    <table class="w-full min-w-[640px] border-collapse text-left">
                      <thead>
                        <tr class="border-b border-base-200 dark:border-base-800">
                          {section.table.headers.map((header) => (
                            <th
                              scope="col"
                              class="py-3 pr-4 last:pr-0 text-sm font-medium text-base-900 dark:text-white uppercase tracking-wide"
                            >
                              {header}
                            </th>
                          ))}
                        </tr>
                      </thead>
                      <tbody>
                        {section.table.rows.map((row) => (
                          <tr class="border-b border-base-200 dark:border-base-800">
                            {row.cells.map((cell) => (
                              <td class="py-3 pr-4 last:pr-0 text-base text-base-500 dark:text-base-400 align-top">
                                {cell}
                              </td>
                            ))}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )
              }
            </div>
            {
              section.embed && (
                <ItinerariModalEmbed
                  title={section.embed.title}
                  iframeTitle={section.embed.iframeTitle}
                  src={section.embed.src}
                  caption={section.embed.caption}
                  link={section.embed.link}
                  linkLabel={section.embed.linkLabel}
                />
              )
            }
            {
              section.media && section.mediaAfterParagraph === undefined && (
                <ItinerariModalPublicMedia
                  media={section.media}
                  zoomId={`${zoomId}-section-${sectionIndex}`}
                />
              )
            }
          </div>
        ))
      }
    </div>

    {
      images.length > 0 && (
        <ItinerariZoom zoomId={zoomId}>
          <div class="mt-10 flex flex-col gap-6 border-t border-base-200 dark:border-base-800 pt-8">
            <Text
              tag="h3"
              variant="displaySM"
              class="dark:text-white text-base-900 font-medium"
            >
              Mapes i figures
            </Text>
            {images.map((image) =>
              isPublicMedia(image) ? (
                <figure>
                  <button
                    type="button"
                    class={zoomThumbClass}
                    data-itinerari-zoom
                    data-full-src={withBase(image.publicSrc)}
                    aria-label={`Ampliar: ${image.alt}`}
                  >
                    <img
                      src={withBase(image.publicSrc)}
                      alt={image.alt}
                      class={zoomImageClass}
                      loading="lazy"
                      decoding="async"
                    />
                  </button>
                  {
                    image.caption && (
                      <figcaption class="mt-2 text-sm text-base-500 dark:text-base-400 text-center">
                        {image.caption}
                      </figcaption>
                    )
                  }
                </figure>
              ) : (
                <figure>
                  <button
                    type="button"
                    class={zoomThumbClass}
                    data-itinerari-zoom
                    data-full-src={image.url.src}
                    aria-label={`Ampliar: ${image.alt}`}
                  >
                    <Image
                      src={image.url}
                      alt={image.alt}
                      width={1200}
                      height={800}
                      class={zoomImageClass}
                    />
                  </button>
                  {
                    image.caption && (
                      <figcaption class="mt-2 text-sm text-base-500 dark:text-base-400 text-center">
                        {image.caption}
                      </figcaption>
                    )
                  }
                </figure>
              ),
            )}
          </div>
        </ItinerariZoom>
      )
    }
  </div>
</dialog>

<script>
  import { bindDialogTrigger } from "@/utils/modalA11y";

  function initItinerariDadaModals() {
    document.querySelectorAll("[data-modal-target]").forEach((btn) => {
      if (!(btn instanceof HTMLElement)) return;
      if (btn.dataset.bound) return;
      btn.dataset.bound = "true";

      const modalId = btn.dataset.modalTarget;
      if (!modalId) return;

      const dialog = document.getElementById(modalId);
      if (!(dialog instanceof HTMLDialogElement)) return;

      bindDialogTrigger(btn, dialog, {
        onBeforeClose: () => {
          dialog.querySelectorAll("video").forEach((video) => video.pause());
        },
      });
    });
  }

  initItinerariDadaModals();
  document.addEventListener("astro:after-swap", initItinerariDadaModals);
</script>
