---
interface Props {
  src: string;
  title: string;
  /** Mostra control per activar/desactivar el so (autoplay segueix silenciat) */
  sound?: boolean;
}

const { src, title, sound = false } = Astro.props;
---

<div
  class="itinerari-hero-video relative w-full aspect-video overflow-hidden bg-base-200 dark:bg-base-800"
  data-itinerari-hero-video
  data-sound={sound ? "true" : "false"}
>
  <video
    class="size-full object-cover"
    src={src}
    title={title}
    autoplay
    muted
    playsinline
    preload="auto"
    disablepictureinpicture
    tabindex="-1"
    controlslist="nodownload nofullscreen noremoteplayback"
  />

  {
    sound && (
      <button
        type="button"
        class="itinerari-hero-video__sound absolute bottom-4 right-4 z-10 inline-flex size-14 items-center justify-center rounded-full border-0 bg-white/90 p-0 text-base-900 shadow-lg cursor-pointer transition-transform hover:scale-105"
        aria-label="Activar so"
        aria-pressed="false"
      >
        <svg
          class="itinerari-hero-video__sound-on hidden size-7"
          viewBox="0 0 24 24"
          fill="currentColor"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.06c1.48-.74 2.5-2.26 2.5-4.03zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"></path>
        </svg>
        <svg
          class="itinerari-hero-video__sound-off size-7"
          viewBox="0 0 24 24"
          fill="currentColor"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3 3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4 9.91 6.09 12 8.18V4z"></path>
        </svg>
      </button>
    )
  }

  <button
    type="button"
    class="itinerari-hero-video__replay absolute bottom-4 right-4 z-10 hidden size-14 items-center justify-center rounded-full border-0 bg-white/90 p-0 text-base-900 shadow-lg cursor-pointer transition-transform hover:scale-105"
    aria-label="Reproduir el vídeo de nou"
  >
    <svg
      class="size-7 ml-0.5"
      viewBox="0 0 24 24"
      fill="currentColor"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path d="M8 5.14v13.72L19 12 8 5.14z"></path>
    </svg>
  </button>
</div>

<script>
  document.querySelectorAll("[data-itinerari-hero-video]").forEach((root) => {
    const video = root.querySelector("video");
    const replay = root.querySelector(".itinerari-hero-video__replay");
    const soundBtn = root.querySelector(".itinerari-hero-video__sound");
    const soundOn = root.querySelector(".itinerari-hero-video__sound-on");
    const soundOff = root.querySelector(".itinerari-hero-video__sound-off");
    const hasSound = root.dataset.sound === "true";

    if (!(video instanceof HTMLVideoElement) || !(replay instanceof HTMLButtonElement)) {
      return;
    }

    video.controls = false;

    const updateSoundButton = () => {
      if (!(soundBtn instanceof HTMLButtonElement)) return;

      const muted = video.muted;
      soundBtn.setAttribute("aria-label", muted ? "Activar so" : "Silenciar");
      soundBtn.setAttribute("aria-pressed", muted ? "false" : "true");
      soundOn?.classList.toggle("hidden", muted);
      soundOff?.classList.toggle("hidden", !muted);
    };

    const showReplay = () => {
      replay.classList.remove("hidden");
      replay.classList.add("inline-flex");
      if (hasSound && soundBtn instanceof HTMLButtonElement) {
        soundBtn.classList.add("hidden");
      }
    };

    const hideReplay = () => {
      replay.classList.add("hidden");
      replay.classList.remove("inline-flex");
      if (hasSound && soundBtn instanceof HTMLButtonElement) {
        soundBtn.classList.remove("hidden");
      }
    };

    video.addEventListener("ended", showReplay);

    video.addEventListener("error", showReplay);

    if (hasSound && soundBtn instanceof HTMLButtonElement) {
      updateSoundButton();

      soundBtn.addEventListener("click", () => {
        video.muted = !video.muted;
        updateSoundButton();
        void video.play();
      });
    }

    replay.addEventListener("click", () => {
      hideReplay();
      video.currentTime = 0;
      if (hasSound) {
        video.muted = false;
        updateSoundButton();
      }
      void video.play();
    });

    void video.play().catch(() => {
      showReplay();
    });

    video.addEventListener("contextmenu", (event) => {
      event.preventDefault();
    });
  });
</script>

<style>
  .itinerari-hero-video[data-sound="true"] .itinerari-hero-video__replay {
    right: 5.5rem;
  }

  .itinerari-hero-video video::-webkit-media-controls {
    display: none !important;
  }

  .itinerari-hero-video video::-webkit-media-controls-enclosure {
    display: none !important;
  }
</style>
