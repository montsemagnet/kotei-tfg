---
interface Props {
  title?: string;
  iframeTitle: string;
  src: string;
  caption?: string;
  link?: string;
  linkLabel?: string;
}

const {
  title,
  iframeTitle,
  src,
  caption,
  link,
  linkLabel = "Obrir al repositori de la Generalitat de Catalunya",
} = Astro.props;

const isDev = import.meta.env.DEV;

const linkClass =
  "inline-flex items-center justify-center rounded-full border border-base-200 dark:border-base-700 bg-base-100 dark:bg-base-800 px-4 py-2 text-sm font-medium text-base-900 dark:text-white hover:bg-base-200 dark:hover:bg-base-700 transition-colors";
---

<figure class="itinerari-modal-embed my-6">
  {
    title && (
      <figcaption class="mb-3 text-base font-medium text-base-900 dark:text-white leading-snug">
        {title}
      </figcaption>
    )
  }

  {
    isDev ? (
      <div class="max-w-md rounded-md border border-dashed border-base-300 dark:border-base-700 bg-base-50 dark:bg-base-950/40 px-5 py-8 text-center">
        <p class="text-sm text-base-600 dark:text-base-300 leading-relaxed">
          La visualització incrustada del geotop no es pot previsualitzar en mode
          desenvolupament local (el repositori de la Generalitat limita les
          peticions des d&apos;aquest entorn).
        </p>
        {
          link && (
            <p class="mt-4">
              <a href={link} target="_blank" rel="noopener noreferrer" class={linkClass}>
                {linkLabel}
              </a>
            </p>
          )
        }
      </div>
    ) : (
      <>
        <div class="overflow-hidden rounded-md border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-950/40">
          <div class="relative aspect-[4/3] w-full max-w-md">
            <iframe
              src={src}
              title={iframeTitle}
              class="absolute inset-0 size-full border-0"
              loading="lazy"
              scrolling="no"
              allowfullscreen
            />
          </div>
        </div>
        {
          link && (
            <p class="mt-3">
              <a href={link} target="_blank" rel="noopener noreferrer" class={linkClass}>
                {linkLabel}
              </a>
            </p>
          )
        }
      </>
    )
  }

  {
    caption && (
      <figcaption class="mt-2 text-sm text-base-500 dark:text-base-400 leading-relaxed">
        {caption}
        {!isDev && " Si la miniatura no es carrega, utilitzeu l'enllaç superior."}
      </figcaption>
    )
  }
</figure>
