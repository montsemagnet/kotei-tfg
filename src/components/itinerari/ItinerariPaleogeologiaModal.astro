---
import { withBase } from "@/utils/withBase";
import ItinerariModalHeaderActions from "@/components/itinerari/ItinerariModalHeaderActions.astro";

interface Video {
  id?: string;
  title: string;
  publicSrc?: string;
  captionsSrc?: string;
  alt?: string;
  period?: string;
  description?: string;
  paragraphs?: string[];
}

interface Section {
  title: string;
  paragraphs: string[];
}

interface Props {
  modalId: string;
  label: string;
  intro?: string;
  videos?: Video[];
  sections?: Section[];
}

const { modalId, label, intro, videos = [], sections = [] } = Astro.props;

const titleId = `${modalId}-title`;

const videoClass =
  "w-full aspect-video rounded-md border border-base-200 dark:border-base-800 bg-base-950";

const captionsIconOn = withBase("/images/ui/subtitols-activats.png");
const captionsIconOff = withBase("/images/ui/subtitols-desactivats.png");
const panelCloseClass =
  "itinerari-dada-close rounded-full bg-base-200 dark:bg-base-800 px-4 py-2 text-sm text-base-900 dark:text-white hover:bg-base-300 dark:hover:bg-base-700";

function videoAnchorId(video: Video, index: number): string {
  if (video.id) return `${modalId}-${video.id}`;
  return `${modalId}-apartat-${index + 1}`;
}
---

<dialog
  id={modalId}
  class="itinerari-dada-dialog fixed inset-0 z-[110] m-0 size-full max-h-none max-w-none border-0 bg-base-950/90 p-4 backdrop:bg-transparent open:flex open:items-start open:justify-center overflow-y-auto"
  aria-modal="true"
  aria-labelledby={titleId}
  data-focus-trap="true"
>
  <div
    class="itinerari-dada-panel relative my-8 w-full max-w-3xl rounded-lg bg-base-100 dark:bg-base-900 p-6 lg:p-10 shadow-xl"
    data-text-size-enabled="true"
  >
    <ItinerariModalHeaderActions closeClass={panelCloseClass} />

    <div class="itinerari-modal-text-content">
      <h2
        id={titleId}
        class="text-2xl md:text-3xl lg:text-4xl dark:text-white text-base-900 font-medium tracking-tighter mb-6 pr-52 capitalize"
      >
        {label}
      </h2>

      {
        intro && (
          <p class="text-xl md:text-2xl text-base-600 dark:text-base-300 mb-8 leading-relaxed">
            {intro}
          </p>
        )
      }

      {
        videos.length > 1 && (
          <nav
            class="mb-8 rounded-lg border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-950/40 px-4 py-4"
            aria-label="Índex de la paleogeologia"
          >
            <p class="text-sm font-medium uppercase tracking-wide text-base-500 dark:text-base-400 mb-3">
              Índex
            </p>
            <ol class="flex flex-col gap-2 list-none p-0 m-0">
              {
                videos.map((video, index) => (
                  <li>
                    <a
                      href={`#${videoAnchorId(video, index)}`}
                      class="text-base text-accent-700 dark:text-accent-400 underline decoration-accent-700/30 dark:decoration-accent-400/40 underline-offset-[4px] hover:decoration-accent-700 dark:hover:decoration-accent-400 transition-colors leading-snug"
                    >
                      {video.title}
                    </a>
                  </li>
                ))
              }
            </ol>
          </nav>
        )
      }
    </div>

    {
      videos.length > 0 && (
        <ol class="flex flex-col gap-10 list-none p-0 m-0">
          {
            videos.map((video, index) => (
              <li id={videoAnchorId(video, index)} class="scroll-mt-28">
                <div class="itinerari-modal-text-content mb-3">
                  {
                    videos.length > 1 && (
                      <h3 class="text-xl md:text-2xl lg:text-3xl dark:text-white text-base-900 font-medium">
                        {video.title}
                      </h3>
                    )
                  }
                  {
                    video.period && (
                      <p class="mt-1 text-sm uppercase tracking-wide text-base-500 dark:text-base-400 font-mono">
                        {video.period}
                      </p>
                    )
                  }
                  {
                    video.paragraphs && video.paragraphs.length > 0 ? (
                      <div class="mt-3 flex flex-col gap-3">
                        {
                          video.paragraphs.map((paragraph) => (
                            <p class="text-base text-base-500 dark:text-base-400 leading-relaxed">
                              {paragraph}
                            </p>
                          ))
                        }
                      </div>
                    ) : (
                      video.description && (
                        <p class="mt-2 text-base text-base-500 dark:text-base-400 leading-relaxed">
                          {video.description}
                        </p>
                      )
                    )
                  }
                </div>
                {
                  video.publicSrc && (
                    <div class="flex flex-col gap-2" data-video-captions-wrap>
                      <video
                        class={videoClass}
                        src={withBase(video.publicSrc)}
                        title={video.alt ?? video.title}
                        controls
                        playsinline
                        preload="metadata"
                        data-paleogeologia-video
                      >
                        {
                          video.captionsSrc && (
                            <track
                              kind="subtitles"
                              src={withBase(video.captionsSrc)}
                              srclang="ca"
                              label="Català"
                            />
                          )
                        }
                      </video>
                      {
                        video.captionsSrc && (
                          <button
                            type="button"
                            class="self-start inline-flex items-center gap-2 rounded-md border border-base-200 dark:border-base-700 bg-base-50 dark:bg-base-950/50 px-3 py-2 text-sm font-medium text-base-900 dark:text-white hover:bg-base-100 dark:hover:bg-base-800 transition-colors"
                            data-captions-toggle
                            data-icon-on={captionsIconOn}
                            data-icon-off={captionsIconOff}
                            aria-pressed="false"
                            aria-label="Activar subtítols del vídeo"
                          >
                            <img
                              src={captionsIconOff}
                              alt=""
                              width="28"
                              height="28"
                              class="size-7 shrink-0 object-contain"
                              data-captions-icon
                              decoding="async"
                            />
                            <span data-captions-toggle-label>Subtítols desactivats</span>
                          </button>
                        )
                      }
                    </div>
                  )
                }
              </li>
            ))
          }
        </ol>
      )
    }

    {
      sections.length > 0 && (
        <div class="itinerari-modal-text-content flex flex-col gap-8 mt-10">
          {
            sections.map((section) => (
              <div>
                <h3 class="text-xl md:text-2xl lg:text-3xl dark:text-white text-base-900 font-medium mb-3">
                  {section.title}
                </h3>
                {
                  section.paragraphs.map((paragraph) => (
                    <p class="text-base text-base-500 dark:text-base-400 mb-3 leading-relaxed last:mb-0">
                      {paragraph}
                    </p>
                  ))
                }
              </div>
            ))
          }
        </div>
      )
    }
  </div>
</dialog>

<script>
  function getCaptionsTrack(video: HTMLVideoElement): TextTrack | undefined {
    return Array.from(video.textTracks).find(
      (track) => track.kind === "subtitles" || track.kind === "captions",
    );
  }

  function syncCaptionsToggle(button: HTMLButtonElement, showing: boolean) {
    button.setAttribute("aria-pressed", showing ? "true" : "false");
    button.setAttribute(
      "aria-label",
      showing ? "Desactivar subtítols del vídeo" : "Activar subtítols del vídeo",
    );
    const label = button.querySelector("[data-captions-toggle-label]");
    if (label) {
      label.textContent = showing ? "Subtítols activats" : "Subtítols desactivats";
    }
    const icon = button.querySelector("[data-captions-icon]");
    const iconSrc = showing ? button.dataset.iconOn : button.dataset.iconOff;
    if (icon instanceof HTMLImageElement && iconSrc) {
      icon.src = iconSrc;
    }
  }

  function initPaleogeologiaCaptions() {
    document.querySelectorAll("[data-captions-toggle]").forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      if (button.dataset.captionsBound) return;
      button.dataset.captionsBound = "true";

      const wrap = button.closest("[data-video-captions-wrap]");
      const video = wrap?.querySelector("[data-paleogeologia-video]");
      if (!(video instanceof HTMLVideoElement)) return;

      const initCaptions = () => {
        const track = getCaptionsTrack(video);
        if (!track) return;
        track.mode = "hidden";
        syncCaptionsToggle(button, false);
      };

      if (video.readyState >= 1) {
        initCaptions();
      } else {
        video.addEventListener("loadedmetadata", initCaptions, { once: true });
      }

      button.addEventListener("click", () => {
        const track = getCaptionsTrack(video);
        if (!track) return;
        const showing = track.mode === "showing";
        track.mode = showing ? "hidden" : "showing";
        syncCaptionsToggle(button, !showing);
      });
    });
  }

  initPaleogeologiaCaptions();
  document.addEventListener("astro:after-swap", initPaleogeologiaCaptions);
</script>
