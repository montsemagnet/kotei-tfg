---
import ItinerariModalHeaderActions from "@/components/itinerari/ItinerariModalHeaderActions.astro";

interface Props {
  zoomId: string;
}

const { zoomId } = Astro.props;
const overlayCloseClass =
  "itinerari-zoom-close rounded-full bg-white/10 px-4 py-2 text-white hover:bg-white/20";
---

<div data-itinerari-zoom-root={zoomId}>
  <slot />

  <dialog
    id={`itinerari-zoom-${zoomId}`}
    class="itinerari-zoom-dialog fixed inset-0 z-[120] m-0 size-full max-h-none max-w-none border-0 bg-base-950/90 p-4 backdrop:bg-transparent open:flex open:items-center open:justify-center"
    aria-modal="true"
    data-focus-trap="true"
  >
    <div class="relative w-full max-w-6xl mx-auto">
      <ItinerariModalHeaderActions
        closeClass={overlayCloseClass}
        showTextSize={false}
      />
      <figure class="max-w-6xl w-full">
        <img
          class="itinerari-zoom-image w-full max-h-[90vh] object-contain mx-auto"
          src=""
          alt=""
        />
        <figcaption
          class="itinerari-zoom-caption mt-4 text-center text-white text-sm"
        />
      </figure>
    </div>
  </dialog>
</div>

<script>
  import { openDialogFromTrigger } from "@/utils/modalA11y";

  function initItinerariZoom() {
    document.querySelectorAll("[data-itinerari-zoom-root]").forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      if (root.dataset.bound) return;
      root.dataset.bound = "true";

      const zoomId = root.dataset.itinerariZoomRoot;
      if (!zoomId) return;

      const dialog = root.querySelector(".itinerari-zoom-dialog");
      if (!(dialog instanceof HTMLDialogElement)) return;

      const previewImage = dialog.querySelector(".itinerari-zoom-image");
      const previewCaption = dialog.querySelector(".itinerari-zoom-caption");

      if (
        !(previewImage instanceof HTMLImageElement) ||
        !(previewCaption instanceof HTMLElement)
      ) {
        return;
      }

      root.querySelectorAll("[data-itinerari-zoom]").forEach((btn) => {
        if (!(btn instanceof HTMLButtonElement)) return;
        if (btn.dataset.zoomBound) return;
        btn.dataset.zoomBound = "true";

        btn.addEventListener("click", (event) => {
          event.stopPropagation();
          const thumb = btn.querySelector("img");
          if (!(thumb instanceof HTMLImageElement)) return;

          previewImage.src =
            btn.dataset.fullSrc || thumb.currentSrc || thumb.src;
          previewImage.alt = thumb.alt;
          previewCaption.textContent = thumb.alt;
          openDialogFromTrigger(dialog, btn);
        });
      });
    });
  }

  initItinerariZoom();
  document.addEventListener("astro:after-swap", initItinerariZoom);
</script>
