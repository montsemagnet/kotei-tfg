---
import fs from "node:fs";
import path from "node:path";
import { getCollection } from "astro:content";
import {
  SAU_TAVERTET_PARADES,
  paradaDisplayLabel,
} from "@/data/sau-tavertet-parades";
import { getParadaSlug } from "@/utils/paradaSlug";
import { withBase } from "@/utils/withBase";

/** Fitxer SVG del mapa — substitueix-lo per actualitzar el mapa */
const MAPA_SVG_PATH = path.join(
  process.cwd(),
  "public/images/itineraris/mapa-parades.svg",
);

const PARADES_IMAGES_DIR = path.join(process.cwd(), "public/images/parades");
const PREVIEW_EXTENSIONS = ["jpg", "jpeg", "png", "webp"];

function publicAssetUrl(urlPath: string): string {
  if (!urlPath.startsWith("/")) return urlPath;

  const diskPath = path.join(process.cwd(), "public", urlPath.replace(/^\//, ""));
  const dir = path.dirname(diskPath);
  const base = path.basename(diskPath);

  let resolved = diskPath;
  if (!fs.existsSync(resolved) && fs.existsSync(dir)) {
    const match = fs
      .readdirSync(dir)
      .find((name) => name.toLowerCase() === base.toLowerCase());
    if (match) {
      resolved = path.join(dir, match);
    }
  }

  if (!fs.existsSync(resolved)) return withBase(urlPath);

  const { mtimeMs } = fs.statSync(resolved);
  return withBase(`${urlPath}?v=${Math.round(mtimeMs)}`);
}

function findExactParadaPreviewFile(dir: string, slug: string): string | null {
  if (!fs.existsSync(dir)) return null;

  const exactBase = `${slug}-hover`.toLowerCase();

  for (const fileName of fs.readdirSync(dir)) {
    const lower = fileName.toLowerCase();
    const dot = lower.lastIndexOf(".");
    if (dot === -1) continue;

    const ext = lower.slice(dot + 1);
    const base = lower.slice(0, dot);
    if (!PREVIEW_EXTENSIONS.includes(ext) || base !== exactBase) continue;

    return fileName;
  }

  return null;
}

/** Nom exacte: I1-P2-hover.jpg — normalitza majúscules i extensió */
function resolveParadaPreviewUrl(slug: string, configured?: string): string {
  fs.mkdirSync(PARADES_IMAGES_DIR, { recursive: true });

  const found = findExactParadaPreviewFile(PARADES_IMAGES_DIR, slug);
  if (!found) {
    return configured ? publicAssetUrl(configured) : "";
  }

  const canonicalName = `${slug}-hover.jpg`;
  const foundPath = path.join(PARADES_IMAGES_DIR, found);
  const canonicalPath = path.join(PARADES_IMAGES_DIR, canonicalName);

  if (found !== canonicalName) {
    const tempPath = path.join(PARADES_IMAGES_DIR, `${slug}-hover.__tmp.jpg`);
    fs.copyFileSync(foundPath, tempPath);
    try {
      fs.unlinkSync(foundPath);
    } catch {
      /* Windows: mateix fitxer amb extensió diferent */
    }
    fs.renameSync(tempPath, canonicalPath);
  }

  const { mtimeMs } = fs.statSync(canonicalPath);
  return withBase(`/images/parades/${canonicalName}?v=${Math.round(mtimeMs)}`);
}

const paradesDisponibles = new Set(
  (await getCollection("parades")).map((entry) => getParadaSlug(entry)),
);

const paradesMapData = SAU_TAVERTET_PARADES.map((parada) => ({
  svgIds: parada.svgIds,
  slug: parada.slug,
  label: paradaDisplayLabel(parada),
  preview: resolveParadaPreviewUrl(parada.slug, parada.preview),
  disponible: paradesDisponibles.has(parada.slug),
}));

const mapaSvg = fs.existsSync(MAPA_SVG_PATH)
  ? fs
      .readFileSync(MAPA_SVG_PATH, "utf-8")
      .replace(/<\?xml[^?]*\?>\s*/i, "")
      .replace(/<!DOCTYPE[^>]*>\s*/i, "")
  : "";
---

<div class="itinerari-sau-map relative w-full" data-itinerari-map>
  <div
    class="parada-preview pointer-events-none absolute z-30 hidden w-64 overflow-hidden rounded-lg border border-base-200 bg-white shadow-xl dark:border-base-700 dark:bg-base-900"
    role="tooltip"
    aria-hidden="true"
  >
    <img
      width="640"
      height="480"
      src=""
      alt=""
      class="block h-auto w-full object-cover"
    />
    <p
      class="parada-preview-label px-3 py-2 text-sm text-base-700 dark:text-base-300"
    >
    </p>
  </div>

  {
    mapaSvg ? (
      <>
        <div class="itinerari-sau w-full [&>svg]:h-auto [&>svg]:w-full" set:html={mapaSvg} />
        <p class="itinerari-sau-hint mt-3 text-center text-sm text-base-500 dark:text-base-400">
          Clica sobre les parades per veure el seu contingut.
        </p>
      </>
    ) : (
      <p class="rounded-lg border border-dashed border-base-300 px-4 py-8 text-center text-sm text-base-500">
        Mapa no trobat. Col·loca el fitxer{" "}
        <code class="text-base-700">public/images/itineraris/mapa-parades.svg</code>.
      </p>
    )
  }
</div>

<style>
  @keyframes parada-circle-pulse {
    0%,
    100% {
      fill: rgba(220, 252, 231, 0.9);
      stroke: #1f5a45;
    }
    50% {
      fill: rgba(134, 239, 172, 0.95);
      stroke: #15803d;
    }
  }

  @keyframes parada-ring-pulse {
    0%,
    100% {
      stroke: #1f5a45;
      stroke-width: 3;
      opacity: 0.55;
    }
    50% {
      stroke: #16a34a;
      stroke-width: 5;
      opacity: 1;
    }
  }

  .itinerari-sau-map :global(.parada-hotspot) {
    outline: none;
    pointer-events: all;
  }

  .itinerari-sau-map :global(.parada-hotspot--disponible) {
    cursor: pointer;
  }

  .itinerari-sau-map :global(.parada-hotspot--pendent) {
    cursor: help;
  }

  .itinerari-sau-map :global(.parada-ring) {
    fill: none;
    pointer-events: none;
    animation: parada-ring-pulse 2.2s ease-in-out infinite;
  }

  .itinerari-sau-map :global(.parada-hit-area) {
    fill: rgba(31, 90, 69, 0.14);
    stroke: none;
    opacity: 1;
  }

  .itinerari-sau-map :global(.parada-circle) {
    fill: rgba(255, 252, 252, 0.88);
    stroke: #1f5a45;
    stroke-width: 3;
    transition:
      fill 0.2s ease,
      stroke 0.2s ease,
      stroke-width 0.2s ease;
  }

  .itinerari-sau-map :global(.parada-hotspot--disponible .parada-circle) {
    animation: parada-circle-pulse 2.2s ease-in-out infinite;
  }

  .itinerari-sau-map :global(.parada-hotspot--pendent .parada-circle) {
    stroke-dasharray: 6 4;
    stroke: #6b7280;
    fill: rgba(255, 255, 255, 0.65);
  }

  .itinerari-sau-map :global(.parada-hotspot--disponible:hover .parada-hit-area),
  .itinerari-sau-map :global(.parada-hotspot--disponible:focus-visible .parada-hit-area) {
    fill: rgba(31, 90, 69, 0.32);
  }

  .itinerari-sau-map :global(.parada-hotspot:hover .parada-circle),
  .itinerari-sau-map :global(.parada-hotspot:focus-visible .parada-circle) {
    animation: none;
    fill: rgba(187, 247, 208, 0.98);
    stroke: #15803d;
    stroke-width: 4;
  }

  .itinerari-sau-map :global(.parada-hotspot:hover .parada-ring),
  .itinerari-sau-map :global(.parada-hotspot:focus-visible .parada-ring) {
    animation: none;
    stroke: #16a34a;
    stroke-width: 6;
    opacity: 1;
  }

  .itinerari-sau-map :global(.parada-hotspot--disponible:active .parada-circle) {
    fill: #86efac;
    stroke: #14532d;
  }

  @media (prefers-reduced-motion: reduce) {
    .itinerari-sau-map :global(.parada-hotspot--disponible .parada-circle),
    .itinerari-sau-map :global(.parada-ring) {
      animation: none;
    }

    .itinerari-sau-map :global(.parada-hotspot--disponible .parada-circle) {
      fill: rgba(220, 252, 231, 0.95);
      stroke: #15803d;
    }
  }
</style>

<script define:vars={{ paradesMapData, baseUrl: import.meta.env.BASE_URL }}>
  const SVG_NS = "http://www.w3.org/2000/svg";
  const XLINK_NS = "http://www.w3.org/1999/xlink";

  function getHotspotLayer(svg) {
    let layer = svg.querySelector("#parada-hotspots");
    if (!layer) {
      layer = document.createElementNS(SVG_NS, "g");
      layer.id = "parada-hotspots";
      svg.appendChild(layer);
    }
    return layer;
  }

  function cloneEllipseLike(el, className) {
    if (!(el instanceof SVGEllipseElement)) return null;

    const clone = el.cloneNode(true);
    clone.removeAttribute("id");
    clone.removeAttribute("style");
    clone.classList.add(className);
    return clone;
  }

  function prepareMarkerElement(el) {
    el.classList.add("parada-circle");
    const opacityMatch = el.getAttribute("style")?.match(/opacity:\s*([\d.]+)/);
    el.removeAttribute("style");
    if (opacityMatch) {
      el.setAttribute("opacity", opacityMatch[1]);
    }
  }

  function findParadaTarget(svg, svgIds) {
    for (const id of svgIds) {
      const el = svg.querySelector(`#${CSS.escape(id)}`);
      if (el instanceof SVGGraphicsElement && !el.closest(".parada-hotspot")) {
        return el;
      }
    }
    return null;
  }

  function setHotspotHref(anchor, slug) {
    const url = `${baseUrl}parades/${slug}`;
    anchor.setAttribute("href", url);
    anchor.setAttributeNS(XLINK_NS, "href", url);
  }

  function buildHotspotAnchor(meta) {
    const anchor = document.createElementNS(SVG_NS, "a");
    anchor.classList.add("parada-hotspot");
    anchor.classList.add(
      meta.disponible ? "parada-hotspot--disponible" : "parada-hotspot--pendent",
    );
    anchor.dataset.label = meta.label;
    anchor.dataset.slug = meta.slug;
    anchor.setAttribute("aria-label", meta.label);

    if (meta.preview) {
      anchor.dataset.preview = meta.preview;
    }

    if (meta.disponible) {
      setHotspotHref(anchor, meta.slug);
    } else {
      anchor.setAttribute("role", "img");
      anchor.setAttribute("tabindex", "0");
    }

    const title = document.createElementNS(SVG_NS, "title");
    title.textContent = meta.label;
    anchor.appendChild(title);

    return anchor;
  }

  function wrapParadaHotspot(svg, target, meta) {
    const anchor = buildHotspotAnchor(meta);
    const ring = cloneEllipseLike(target, "parada-ring");
    const hitArea = cloneEllipseLike(target, "parada-hit-area");

    if (hitArea instanceof SVGEllipseElement) {
      const rx = parseFloat(hitArea.getAttribute("rx") || "0");
      const ry = parseFloat(hitArea.getAttribute("ry") || "0");
      hitArea.setAttribute("rx", String(rx * 1.2));
      hitArea.setAttribute("ry", String(ry * 1.2));
    }

    if (ring) anchor.appendChild(ring);
    if (hitArea) anchor.appendChild(hitArea);

    target.parentNode?.removeChild(target);
    prepareMarkerElement(target);
    anchor.appendChild(target);

    getHotspotLayer(svg).appendChild(anchor);
    return anchor;
  }

  function syncParadaHotspot(hotspot, meta) {
    hotspot.dataset.label = meta.label;
    hotspot.dataset.slug = meta.slug;
    hotspot.setAttribute("aria-label", meta.label);

    if (meta.preview) {
      hotspot.dataset.preview = meta.preview;
    } else {
      delete hotspot.dataset.preview;
    }

    hotspot.classList.remove("parada-hotspot--disponible", "parada-hotspot--pendent");
    hotspot.classList.add(
      meta.disponible ? "parada-hotspot--disponible" : "parada-hotspot--pendent",
    );

    if (meta.disponible) {
      setHotspotHref(hotspot, meta.slug);
      hotspot.removeAttribute("role");
      hotspot.removeAttribute("tabindex");
    } else {
      hotspot.removeAttribute("href");
      hotspot.removeAttributeNS(XLINK_NS, "href");
      hotspot.setAttribute("role", "img");
      hotspot.setAttribute("tabindex", "0");
    }

    const marker = hotspot.querySelector(".parada-circle");
    if (marker instanceof SVGGraphicsElement) {
      prepareMarkerElement(marker);
    }
  }

  function bindHotspotNavigation(hotspot) {
    hotspot.addEventListener("click", (event) => {
      if (!hotspot.classList.contains("parada-hotspot--disponible")) return;

      const href = hotspot.getAttribute("href");
      if (!href) return;

      event.preventDefault();
      window.location.assign(href);
    });
  }

  function initItinerariSauMap() {
    document.querySelectorAll("[data-itinerari-map]").forEach((mapRoot) => {
      if (mapRoot.dataset.bound) return;
      mapRoot.dataset.bound = "true";

      const svg = mapRoot.querySelector("svg");
      if (!(svg instanceof SVGSVGElement)) return;

      svg.classList.add("itinerari-sau-svg");
      svg.querySelector("#image1")?.setAttribute("pointer-events", "none");

      const preview = mapRoot.querySelector(".parada-preview");
      const previewImage = preview?.querySelector("img");
      const previewLabel = preview?.querySelector(".parada-preview-label");

      if (
        !(preview instanceof HTMLElement) ||
        !(previewImage instanceof HTMLImageElement) ||
        !(previewLabel instanceof HTMLElement)
      ) {
        return;
      }

      const hotspots = [];

      for (const meta of paradesMapData) {
        const existing = meta.svgIds
          .map((id) => svg.querySelector(`#${CSS.escape(id)}`))
          .find((el) => el?.closest(".parada-hotspot"));

        if (existing) {
          const hotspot = existing.closest(".parada-hotspot");
          syncParadaHotspot(hotspot, meta);
          hotspots.push(hotspot);
          continue;
        }

        const target = findParadaTarget(svg, meta.svgIds);
        if (!target) continue;

        const hotspot = wrapParadaHotspot(svg, target, meta);
        hotspots.push(hotspot);
      }

      const showPreview = (hotspot, event) => {
        const src = hotspot.dataset.preview ?? "";
        const label = hotspot.dataset.label ?? "";
        if (!label && !src) return;

        if (src) {
          previewImage.src = src;
          previewImage.alt = label;
          previewImage.classList.remove("hidden");
        } else {
          previewImage.removeAttribute("src");
          previewImage.classList.add("hidden");
        }

        previewLabel.textContent = label;
        preview.classList.remove("hidden");
        positionPreview(mapRoot, preview, event);
      };

      const hidePreview = () => {
        preview.classList.add("hidden");
        previewImage.removeAttribute("src");
        previewImage.classList.remove("hidden");
      };

      hotspots.forEach((hotspot) => {
        bindHotspotNavigation(hotspot);
        hotspot.addEventListener("mouseenter", (event) => showPreview(hotspot, event));
        hotspot.addEventListener("mousemove", (event) =>
          positionPreview(mapRoot, preview, event),
        );
        hotspot.addEventListener("mouseleave", hidePreview);
        hotspot.addEventListener("focus", (event) => showPreview(hotspot, event));
        hotspot.addEventListener("blur", hidePreview);
      });
    });
  }

  function positionPreview(mapRoot, preview, event) {
    const mapRect = mapRoot.getBoundingClientRect();
    const x = event.clientX - mapRect.left + 16;
    const y = event.clientY - mapRect.top + 16;
    const maxX = mapRect.width - preview.offsetWidth - 8;
    const maxY = mapRect.height - preview.offsetHeight - 8;

    preview.style.left = `${Math.max(8, Math.min(x, maxX))}px`;
    preview.style.top = `${Math.max(8, Math.min(y, maxY))}px`;
  }

  initItinerariSauMap();
  document.addEventListener("astro:after-swap", initItinerariSauMap);
</script>
