---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { project } from "@/data/project";
---

<section>
  <Wrapper variant="standard" class="py-24 lg:py-48">
    <div class="hero-heading flex w-full max-w-full flex-col">
      <Text
        tag="h1"
        variant="display4XL"
        data-aos="fade-down"
        data-aos-duration="1500"
        class="dark:text-white font-medium text-black tracking-tighter"
      >
        {project.title}
      </Text>

      <Text
        tag="p"
        variant="displayLG"
        data-aos="fade-up"
        data-aos-duration="1500"
        data-aos-delay="150"
        class="mt-8 w-full text-pretty text-base-600 dark:text-base-400 leading-snug font-normal lg:text-justify"
      >
        {project.subtitle}
      </Text>

      <a
        href="/itineraris/sau-tavertet"
        title="Veure l'itinerari Sau–Tavertet"
        data-aos="fade-up"
        data-aos-duration="1500"
        data-aos-delay="250"
        class="hero-cta group mt-6 self-end inline-flex items-center gap-4 text-base-900 dark:text-white hover:text-accent-600 dark:hover:text-accent-400 transition-colors duration-300"
      >
        <Text
          tag="span"
          variant="textLG"
          class="font-medium tracking-tight underline decoration-base-300 dark:decoration-base-700 underline-offset-[6px] group-hover:decoration-accent-500 dark:group-hover:decoration-accent-400 transition-colors"
        >
          Veure l'itinerari Sau–Tavertet
        </Text>
        <img
          src="/images/ui/flecha-cta.gif"
          alt=""
          width="56"
          height="40"
          class="hero-cta__arrow h-8 w-auto shrink-0 md:h-10 mix-blend-screen dark:mix-blend-normal"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>
  </Wrapper>
</section>
