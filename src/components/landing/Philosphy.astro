---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import PlateMovementVideo from "@/components/landing/PlateMovementVideo.astro";
import { withBase } from "@/utils/withBase";

const noaaCitation =
  "National Oceanic and Atmospheric Administration. (n.d.). Plate movement: 200 million years ago to today [Vídeo]. NOAA Science on a Sphere.";
const noaaUrl =
  "https://sos.noaa.gov/catalog/datasets/plate-movement-200-million-years-ago-to-today/";

// Array actualitzat amb el contingut per al TFG de Biologia
const philosphy = [
  {
    title: "Itineraris de camp",
    description:
      "Recorreguts geològics per la comarca d’Osona per preparar i ampliar les sortides pràctiques de l'assignatura de geologia.",
  },
  {
    title: "Parades interpretatives",
    description:
      "Punts específics de cada itinerari on s'explica el context geològic i els principals elements d'interès de cada indret.",
  },
  {
    title: "Relació geologia-botànica",
    description:
      "Anàlisi de com el substrat geològic influeix en la vegetació present a cada indret.",
  },
  {
    title: "Anàlisi de roques",
    description:
      "Estudi de mostres i observació petrogràfica amb làmina prima per caracteritzar els materials.",
  },
  {
    title: "Cartografia amb QGIS",
    description:
      "Mapes temàtics per visualitzar la geologia, la vegetació i la distribució espacial dels punts d’estudi.",
  },
  {
    title: "Suport a l'aprenentatge",
    description:
      "Un recurs digital pensat perquè l'alumnat pugui estudiar i revisar els continguts de les sortides de camp.",
  },
  {
    title: "Inclusió i accessibilitat",
    description:
      "Aquest recurs digital amplia l'accés als continguts de camp i facilita el seguiment de l'assignatura a l'alumnat que no pot participar en les sortides.",
  },
  {
    title: "Compromís amb els ODS",
    descriptionBefore:
      "El projecte s'alinea amb els ",
    descriptionLink: {
      text: "Objectius de Desenvolupament Sostenible",
      url: "https://www.un.org/sustainabledevelopment/es/",
    },
    descriptionAfter:
      ", especialment amb l'ODS 4 (Educació de qualitat), en oferir materials docents accessibles i ben estructurats; amb l'ODS 10 (Reducció de les desigualtats), en proporcionar alternatives digitals per a l'aprenentatge de camp; i amb l'ODS 15 (Vida terrestre), en promoure la comprensió de la geologia, la vegetació i la conservació dels ecosistemes terrestres.",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-24">
    <div
      class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-4 gap-4 overflow-hidden"
    >
      <div class="flex flex-col">
        <Text
          tag="h3"
          variant="displayXL"
          data-aos="fade-up"
          data-aos-duration="1000"
          class="dark:text-white text-base-900 font-medium tracking-tighter text-balance"
          >Què hi trobaràs
        </Text>
        <PlateMovementVideo
          src={withBase("/videos/inici/plate_movement_400.mp4")}
          citation={noaaCitation}
          citationUrl={noaaUrl}
        />
      </div>
      <div
        class="flex flex-col sm:col-span-2 lg:col-span-3 divide-y divide-base-200 dark:divide-base-800 border-y border-base-200 dark:border-base-800"
      >
        {
          philosphy.map((process, index) => (
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-2 lg:gap-6 py-4">
              <Text
                tag="h4"
                variant="textLG"
                data-aos="fade-up"
                data-aos-duration="1500"
                class="dark:text-white text-base-900 font-medium tracking-tight text-balance lg:pr-2"
              >
                <span>(0{index + 1})</span>{" "}
                {process.title}
              </Text>
              <div class="lg:col-span-2 overflow-hidden">
                <Text
                  tag="p"
                  variant="textLG"
                  data-aos="fade-up"
                  data-aos-duration="2000"
                  class="dark:text-base-400 text-base-700 leading-relaxed"
                >
                  {
                    process.descriptionLink ? (
                      <>
                        {process.descriptionBefore}
                        <a
                          href={process.descriptionLink.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-accent-600 dark:text-accent-400 underline decoration-accent-600/30 dark:decoration-accent-400/40 underline-offset-[4px] hover:decoration-accent-600 dark:hover:decoration-accent-400 transition-colors"
                        >
                          {process.descriptionLink.text}
                        </a>
                        {process.descriptionAfter}
                      </>
                    ) : (
                      process.description
                    )
                  }
                </Text>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>