---
// Assets
import { Image } from "astro:assets";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import equipGrup from "@/images/equip/equip-grup.png";
import { teamMembers, teamPhotoOrder } from "@/data/project";

const team = teamPhotoOrder.map((name) => {
  const member = teamMembers.find((m) => m.name === name);
  return {
    name,
    email: member?.email ?? "",
    roles: member?.roles ?? [],
  };
});
---

<section>
  <Wrapper variant="standard" class="py-24">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <div class="flex flex-col">
        <Text
          tag="h3"
          variant="displayXL"
          data-aos="fade-up"
          data-aos-duration="1000"
          class="dark:text-white text-base-900 font-medium tracking-tighter"
        >
          Equip
        </Text>
      </div>
      <div class="lg:col-span-3 flex flex-col gap-4 max-w-sm">
        <Image
          src={equipGrup}
          alt="Dra. Núria Ferrer Ramos, Montserrat Magnet Sabata i Dra. Judit Molera Marimon"
          width={360}
          height={240}
          class="w-full rounded-sm object-cover object-center"
        />
        <div class="flex flex-col gap-5">
          {
            team.map((member, index) => (
              <div class="min-w-0">
                <Text
                  tag="p"
                  variant="textBase"
                  class="leading-snug text-base-900 dark:text-white font-medium"
                >
                  (0{index + 1}) {member.name}
                </Text>
                {
                  member.roles.length > 0 && (
                    <Text
                      tag="p"
                      variant="textSM"
                      class="mt-0.5 text-base-600 dark:text-base-300 font-medium"
                    >
                      {member.roles.join(" · ")}
                    </Text>
                  )
                }
                <a
                  href={`mailto:${member.email}`}
                  class="mt-1 block text-sm text-base-500 dark:text-base-400 hover:text-accent-500 dark:hover:text-accent-300 duration-300 break-all"
                >
                  {member.email}
                </a>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>
