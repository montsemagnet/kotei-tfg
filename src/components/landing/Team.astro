---
// Assets
import { Image } from "astro:assets";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import equipGrup from "@/images/equip/equip-grup.png";

// Order matches the group photo: left → right
const team = [
  {
    name: "Dra. Núria Ferrer Ramos",
    url: "https://mon.uvic.cat/fcte/nuria-ferrer-ramos/",
  },
  {
    name: "Montserrat Magnet Sabata",
    url: undefined,
  },
  {
    name: "Dra. Judit Molera Marimon",
    url: "https://mon.uvic.cat/fcte/judit-molera-marimon/",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-24">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <div class="flex flex-col">
        <Text
          tag="h3"
          variant="displayXL"
          data-aos="fade-up"
          data-aos-duration="1000"
          class="dark:text-white text-base-900 font-medium tracking-tighter"
        >
          equip
        </Text>
      </div>
      <div class="lg:col-span-3 flex flex-col gap-4 max-w-xs">
        <Image
          src={equipGrup}
          alt="Dra. Núria Ferrer Ramos, Montserrat Magnet Sabata i Dra. Judit Molera Marimon"
          width={360}
          height={240}
          class="w-full rounded-sm object-cover object-center"
        />
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          {
            team.map((member, index) => (
              <div
                class:list={[
                  index === 0 && "sm:text-left",
                  index === 1 && "sm:text-center",
                  index === 2 && "sm:text-right",
                ]}
              >
                {
                  member.url ? (
                    <Text
                      tag="a"
                      variant="textSM"
                      href={member.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="leading-snug text-base-900 dark:text-white hover:text-base-500"
                    >
                      (0{index + 1}) {member.name}
                    </Text>
                  ) : (
                    <Text
                      tag="p"
                      variant="textSM"
                      class="leading-snug text-base-900 dark:text-white"
                    >
                      (0{index + 1}) {member.name}
                    </Text>
                  )
                }
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>
