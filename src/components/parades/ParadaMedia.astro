---
import { Image } from "astro:assets";
import ItinerariHeroVideo from "@/components/itinerari/ItinerariHeroVideo.astro";

interface Props {
  media: {
    tipus: "foto" | "video";
    foto?: { url: ImageMetadata; alt: string };
    videoUrl?: string;
    publicSrc?: string;
    alt?: string;
  };
}

const { media } = Astro.props;
---

<div data-aos="fade-up" data-aos-duration="1000" class="relative overflow-hidden">
  {
    media.tipus === "foto" && media.foto && (
      <Image
        src={media.foto.url}
        alt={media.foto.alt}
        width={1200}
        height={675}
        class="w-full aspect-[16/9] object-cover"
      />
    )
  }
  {
    media.tipus === "video" && media.publicSrc && (
      <ItinerariHeroVideo
        src={media.publicSrc}
        title={media.alt ?? "Vídeo de la parada"}
      />
    )
  }
  {
    media.tipus === "video" && !media.publicSrc && media.videoUrl && (
      <div class="aspect-video w-full">
        <iframe
          src={media.videoUrl}
          title="Vídeo de la parada"
          class="size-full border-0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        />
      </div>
    )
  }
</div>
