---
// Foundations
import "../styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
// Components
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/Navigation.astro";
// Scripts
import AOSBody from "@/components/fundations/scripts/AOSBody.astro";
// Hides nav and footer on selected screens by passing
// the hideNav and hideFooter props
// <BaseLayout hideNav={true} hideFooter={true}>
const { hideNav = false, hideFooter = false } = Astro.props;
---

<html lang="ca" class="scroll-smooth">
  <head>
    <BaseHead />
  </head>
  <body class="dark:bg-base-900 bg-base-100 min-h-screen">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:rounded-md focus:bg-base-100 focus:px-4 focus:py-2 focus:text-base-900 focus:shadow-lg dark:focus:bg-base-800 dark:focus:text-white"
    >
      Saltar al contingut principal
    </a>
    {!hideNav && <Navigation />}

    <main id="main" class="grow pb-32"><slot /></main>
    {!hideFooter && <Footer />}
    <AOSBody />
  </body>
</html>
