---
// Assets
import { Image } from "astro:assets";
// Layouts i Components
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ItinerariHeroVideo from "@/components/itinerari/ItinerariHeroVideo.astro";
import ItinerariSau from "@/components/itinerari/itinerari-sau.astro";
import ItinerariPaleogeologiaModal from "@/components/itinerari/ItinerariPaleogeologiaModal.astro";
import ItinerariDadaModal from "@/components/itinerari/ItinerariDadaModal.astro";
import ItinerariZoom from "@/components/itinerari/ItinerariZoom.astro";

const { frontmatter } = Astro.props;

const defaultDadesLabels: Record<string, string> = {
  ubicacio: "ubicació",
  mapa: "mapa",
  socle: "sòcol",
  historia: "història",
  paleogeologia: "paleogeologia",
  paisatge: "paisatge i flora",
};

const dadesLabels: Record<string, string> = {
  ...defaultDadesLabels,
  ...frontmatter.dadesLabels,
};
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24 lg:py-48">
      <Text
        tag="a"
        variant="textXS"
        href="/"
        class="uppercase text-base-500 hover:text-base-900 dark:hover:text-white mb-6 inline-block"
      >
        ← Tornar a la pàgina d'inici
      </Text>

      <div class="w-full itinerari-title-wrap">
        <Text
          tag="h1"
          variant="textBase"
          data-aos="fade-up"
          data-aos-duration="1000"
          class="itinerari-page-title dark:text-white text-base-900 font-medium tracking-tighter mb-8 w-full max-w-none"
        >
          {
            frontmatter.titleParts ? (
              <>
                {
                  frontmatter.titleParts.lead && (
                    <>
                      {frontmatter.titleParts.lead}
                      <span class="itinerari-title-from">
                        {frontmatter.titleParts.from}
                      </span>
                    </>
                  )
                }
                {!frontmatter.titleParts.lead && frontmatter.titleParts.from}
                <span class="itinerari-title-arrow" aria-hidden="true">
                  →
                </span>
                {frontmatter.titleParts.to}
              </>
            ) : (
              frontmatter.title
            )
          }
        </Text>

        <div
          data-aos="fade-up"
          data-aos-duration="1000"
          class="relative overflow-hidden mb-12 w-full"
        >
          {
            frontmatter.video ? (
              <ItinerariHeroVideo
                src={frontmatter.video.publicSrc}
                title={frontmatter.video.alt}
              />
            ) : (
              <Image
                width={1000}
                height={500}
                src={frontmatter.thumbnail.url}
                alt={frontmatter.thumbnail.alt}
                class="w-full object-cover"
              />
            )
          }
        </div>
      </div>

      {
        frontmatter.mapa === "sau-tavertet" && (
          <div
            data-aos="fade-up"
            data-aos-duration="1000"
            class="w-full flex justify-center mt-8"
          >
            <div class="max-w-2xl w-full">
              <ItinerariSau />
            </div>
          </div>
        )
      }
    </Wrapper>

    <Wrapper variant="standard" class="py-8">
      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class="grid grid-cols-1 lg:grid-cols-4 items-start gap-x-6 gap-y-2 mb-12"
      >
        <div class="min-w-0">
          <Text
            tag="h4"
            variant="displayMD"
            class="dark:text-white text-base-900 font-medium tracking-tighter capitalize leading-tight break-words"
            >{frontmatter.introLabel ?? "intro"}</Text
          >
        </div>
        <div class="lg:col-span-3 min-w-0">
          {
            frontmatter.intro.map((item) =>
              item.paragraphs?.map((p) => (
                <Text
                  tag="p"
                  variant="textXL"
                  class="text-base-500 dark:text-base-400 mb-4 last:mb-0"
                >
                  {p}
                </Text>
              )),
            )
          }
        </div>
      </div>

      <div class="flex flex-col border-t border-base-200 dark:border-base-800 mb-12">
        {
          Object.entries(frontmatter.dades).map(([key, value]) => {
            const modalKey = frontmatter.dadesModalAliases?.[key] ?? key;
            const modal = frontmatter.dadesModals?.[modalKey];
            const label = dadesLabels[key] ?? key;
            const modalId = `itinerari-modal-${modalKey}`;

            return (
              <div
                data-aos="fade-up"
                data-aos-duration="1000"
                class="grid grid-cols-1 lg:grid-cols-4 items-start gap-x-6 gap-y-2 py-4 border-b border-base-200 dark:border-base-800"
              >
                <div class="min-w-0">
                {
                  modal ? (
                    <button
                      type="button"
                      data-modal-target={modalId}
                      class="text-left cursor-pointer group flex flex-wrap items-center gap-2 w-full max-w-full"
                      aria-haspopup="dialog"
                      aria-label={`Obrir informació: ${label}`}
                    >
                      <Text
                        tag="span"
                        variant="displayMD"
                        class="capitalize font-medium tracking-tighter text-accent-700 dark:text-accent-400 underline decoration-accent-700/30 dark:decoration-accent-400/40 underline-offset-[6px] group-hover:decoration-accent-700 dark:group-hover:decoration-accent-400 transition-colors leading-tight break-words"
                      >
                        {label}
                      </Text>
                      <span
                        class="inline-flex size-7 shrink-0 items-center justify-center rounded-full border border-accent-700/25 dark:border-accent-400/30 text-accent-700 dark:text-accent-400 text-sm leading-none group-hover:bg-accent-700/10 dark:group-hover:bg-accent-400/10 transition-colors"
                        aria-hidden="true"
                      >
                        +
                      </span>
                    </button>
                  ) : key === "mapa" && frontmatter.mapaUrl ? (
                    <Text
                      tag="a"
                      variant="displayMD"
                      href={frontmatter.mapaUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      title="Obrir mapa interactiu (nova pestanya)"
                      class="capitalize font-medium tracking-tighter text-accent-700 dark:text-accent-400 underline decoration-accent-700/30 dark:decoration-accent-400/40 underline-offset-[6px] hover:decoration-accent-700 dark:hover:decoration-accent-400 transition-colors leading-tight break-words inline-block"
                    >
                      {label}
                    </Text>
                  ) : (
                    <Text
                      tag="h4"
                      variant="displayMD"
                      class="dark:text-white text-base-900 font-medium tracking-tighter capitalize leading-tight break-words"
                    >
                      {label}
                    </Text>
                  )
                }
                </div>
                {
                  key === "mapa" && frontmatter.mapaUrl ? (
                    <Text
                      tag="a"
                      variant="textXL"
                      href={frontmatter.mapaUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      title="Obrir mapa interactiu (nova pestanya)"
                      class="text-base-500 dark:text-base-400 lg:col-span-3 min-w-0 hover:text-accent-700 dark:hover:text-accent-400 transition-colors"
                    >
                      {value}
                    </Text>
                  ) : (
                    <Text
                      tag="p"
                      variant="textXL"
                      class="text-base-500 dark:text-base-400 lg:col-span-3 min-w-0"
                    >
                      {value}
                    </Text>
                  )
                }
                {
                  modal && modal.videos && modal.videos.length > 0 ? (
                    <ItinerariPaleogeologiaModal
                      modalId={modalId}
                      label={label}
                      intro={modal.intro}
                      videos={modal.videos}
                      sections={modal.sections}
                    />
                  ) : (
                    modal && (
                      <ItinerariDadaModal
                        modalId={modalId}
                        label={label}
                        intro={modal.intro}
                        introMedia={modal.introMedia}
                        sections={modal.sections ?? []}
                        images={modal.images}
                      />
                    )
                  )
                }
              </div>
            );
          })
        }
      </div>

      <ItinerariZoom zoomId="itinerari-page">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-2 mb-12">
          {
            frontmatter.images.map((image) => (
              <div data-aos="fade-up" data-aos-duration="1000">
                <button
                  type="button"
                  class="w-full cursor-pointer overflow-hidden border-0 p-0 bg-transparent hover:opacity-90 transition-opacity"
                  data-itinerari-zoom
                  data-full-src={image.url.src}
                  aria-label={`Ampliar: ${image.alt}`}
                >
                  <Image
                    src={image.url}
                    alt={image.alt}
                    width={600}
                    height={600}
                    class="w-full h-full object-cover"
                  />
                </button>
              </div>
            ))
          }
        </div>
      </ItinerariZoom>

      {
        frontmatter.credits && frontmatter.credits.length > 0 && (
          <div
            data-aos="fade-up"
            data-aos-duration="1000"
            class="grid grid-cols-1 lg:grid-cols-4 gap-2 mt-12"
          >
            <Text
              tag="h4"
              variant="displayXL"
              class="dark:text-white text-base-900 font-medium tracking-tighter"
              >Equip</Text
            >
            <div class="lg:col-span-3 flex flex-col gap-4">
              {
                frontmatter.credits.map((credit) => (
                  <div class="flex justify-between border-b border-base-200 dark:border-base-800 py-4">
                    <Text
                      tag="p"
                      variant="displaySM"
                      class="dark:text-white font-medium"
                    >
                      {credit.name}
                    </Text>
                    <Text
                      tag="p"
                      variant="textXL"
                      class="text-base-500 dark:text-base-400"
                    >
                      {credit.role}
                    </Text>
                  </div>
                ))
              }
            </div>
          </div>
        )
      }

      <slot />
    </Wrapper>
  </section>
</BaseLayout>

<style>
  .itinerari-title-wrap {
    container-type: inline-size;
  }

  .itinerari-page-title {
    white-space: nowrap;
    font-size: clamp(1.875rem, 7.25cqi, 8rem);
    line-height: 1.05;
  }

  .itinerari-title-from {
    margin-left: 0.65em;
  }

  .itinerari-title-arrow {
    margin-left: 0.45em;
    margin-right: 0.25em;
  }

  @media (min-width: 1024px) {
    .itinerari-title-from {
      margin-left: 1em;
    }

    .itinerari-title-arrow {
      margin-left: 0.65em;
    }
  }
</style>
