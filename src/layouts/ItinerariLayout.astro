---
// Assets
import { Image } from "astro:assets";
// Layouts i Components
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ItinerariSau from "@/components/itinerari/itinerari-sau.astro";
import ItinerariDadaModal from "@/components/itinerari/ItinerariDadaModal.astro";
import ItinerariZoom from "@/components/itinerari/ItinerariZoom.astro";

const { frontmatter } = Astro.props;

const dadesLabels: Record<string, string> = {
  ubicacio: "ubicació",
  mapa: "mapa",
  socle: "sòcol",
  historia: "història",
  paisatge: "paisatge i flora",
};
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24 lg:py-48">
      <Text
        tag="a"
        variant="textXS"
        href="/"
        class="uppercase text-base-500 hover:text-base-900 dark:hover:text-white mb-6 inline-block"
      >
        ← Tornar a la pàgina d'inici
      </Text>

      <Text
        tag="h1"
        variant="display5XL"
        data-aos="fade-up"
        data-aos-duration="1000"
        class="dark:text-white text-base-900 font-medium tracking-tighter mb-8"
      >
        {frontmatter.title}
      </Text>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class="relative overflow-hidden mb-12"
      >
        <Image
          width={1000}
          height={500}
          src={frontmatter.thumbnail.url}
          alt={frontmatter.thumbnail.alt}
          class="w-full object-cover"
        />
      </div>

      {
        frontmatter.mapa === "sau-tavertet" && (
          <div
            data-aos="fade-up"
            data-aos-duration="1000"
            class="w-full flex justify-center mt-8"
          >
            <div class="max-w-2xl w-full">
              <ItinerariSau />
            </div>
          </div>
        )
      }
    </Wrapper>

    <Wrapper variant="standard" class="py-8">
      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class="grid grid-cols-1 lg:grid-cols-4 gap-2 mb-12"
      >
        <Text
          tag="h4"
          variant="displayXL"
          class="dark:text-white text-base-900 font-medium tracking-tighter"
          >intro</Text
        >
        <div class="lg:col-span-3">
          {
            frontmatter.intro.map((item) =>
              item.paragraphs?.map((p) => (
                <Text
                  tag="p"
                  variant="displayMD"
                  class="dark:text-white text-black mb-4"
                >
                  {p}
                </Text>
              )),
            )
          }
        </div>
      </div>

      <div class="flex flex-col border-t border-base-200 dark:border-base-800 mb-12">
        {
          Object.entries(frontmatter.dades).map(([key, value]) => {
            const modal = frontmatter.dadesModals?.[key];
            const label = dadesLabels[key] ?? key;
            const modalId = `itinerari-modal-${key}`;

            return (
              <div
                data-aos="fade-up"
                data-aos-duration="1000"
                class="grid grid-cols-1 lg:grid-cols-4 items-baseline gap-2 py-4 border-b border-base-200 dark:border-base-800"
              >
                {
                  modal ? (
                    <button
                      type="button"
                      data-modal-target={modalId}
                      class="text-left cursor-pointer group inline-flex items-center gap-2"
                      aria-haspopup="dialog"
                      aria-label={`Obrir informació: ${label}`}
                    >
                      <Text
                        tag="span"
                        variant="displayXL"
                        class="capitalize font-medium tracking-tighter text-accent-700 dark:text-accent-400 underline decoration-accent-700/30 dark:decoration-accent-400/40 underline-offset-[6px] group-hover:decoration-accent-700 dark:group-hover:decoration-accent-400 transition-colors"
                      >
                        {label}
                      </Text>
                      <span
                        class="inline-flex size-7 shrink-0 items-center justify-center rounded-full border border-accent-700/25 dark:border-accent-400/30 text-accent-700 dark:text-accent-400 text-sm leading-none group-hover:bg-accent-700/10 dark:group-hover:bg-accent-400/10 transition-colors"
                        aria-hidden="true"
                      >
                        +
                      </span>
                    </button>
                  ) : (
                    <Text
                      tag="h4"
                      variant="displayXL"
                      class="dark:text-white text-base-900 font-medium tracking-tighter capitalize"
                    >
                      {label}
                    </Text>
                  )
                }
                <Text
                  tag="p"
                  variant="textXL"
                  class="text-base-500 dark:text-base-400 lg:col-span-3"
                >
                  {value}
                </Text>
                {
                  modal && (
                    <ItinerariDadaModal
                      modalId={modalId}
                      label={label}
                      intro={modal.intro}
                      introMedia={modal.introMedia}
                      sections={modal.sections}
                      images={modal.images}
                    />
                  )
                }
              </div>
            );
          })
        }
      </div>

      <ItinerariZoom zoomId="itinerari-page">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-2 mb-12">
          {
            frontmatter.images.map((image) => (
              <div data-aos="fade-up" data-aos-duration="1000">
                <button
                  type="button"
                  class="w-full cursor-pointer overflow-hidden border-0 p-0 bg-transparent hover:opacity-90 transition-opacity"
                  data-itinerari-zoom
                  data-full-src={image.url.src}
                  aria-label={`Ampliar: ${image.alt}`}
                >
                  <Image
                    src={image.url}
                    alt={image.alt}
                    width={600}
                    height={600}
                    class="w-full h-full object-cover"
                  />
                </button>
              </div>
            ))
          }
        </div>
      </ItinerariZoom>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class="grid grid-cols-1 lg:grid-cols-4 gap-2 mt-12"
      >
        <Text
          tag="h4"
          variant="displayXL"
          class="dark:text-white text-base-900 font-medium tracking-tighter"
          >Equip</Text
        >
        <div class="lg:col-span-3 flex flex-col gap-4">
          {
            frontmatter.credits.map((credit) => (
              <div class="flex justify-between border-b border-base-200 dark:border-base-800 py-4">
                <Text
                  tag="p"
                  variant="displaySM"
                  class="dark:text-white font-medium"
                >
                  {credit.name}
                </Text>
                <Text
                  tag="p"
                  variant="textXL"
                  class="text-base-500 dark:text-base-400"
                >
                  {credit.role}
                </Text>
              </div>
            ))
          }
        </div>
      </div>

      <slot />
    </Wrapper>
  </section>
</BaseLayout>
