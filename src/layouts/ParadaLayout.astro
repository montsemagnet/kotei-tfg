---
import { getEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ParadaMedia from "@/components/parades/ParadaMedia.astro";
import ParadaGallery from "@/components/parades/ParadaGallery.astro";
import ParadaAnalisiFloraModal from "@/components/parades/ParadaAnalisiFloraModal.astro";
import ItinerariDadaModal from "@/components/itinerari/ItinerariDadaModal.astro";
import ItinerariVideoModal from "@/components/itinerari/ItinerariVideoModal.astro";
import { withBase } from "@/utils/withBase";

const { frontmatter, slug } = Astro.props;
const analisiFloraModalId = `parada-flora-${slug}`;
const geologiaModalId = `parada-geologia-${slug}`;
const videoAeriModalId = `parada-aeri-${slug}`;

const itinerariEntry = await getEntry("itineraris", frontmatter.itinerari);
const itinerariTitle = itinerariEntry?.data.title ?? "Itinerari";
const itinerariHref = withBase(`/itineraris/${frontmatter.itinerari}`);

const breadcrumbLink =
  "uppercase text-base-500 hover:text-base-900 dark:hover:text-white transition-colors";
const breadcrumbCurrent =
  "uppercase text-base-900 dark:text-white font-medium";

const sectionGrid =
  "grid grid-cols-1 lg:grid-cols-4 gap-3 lg:gap-8 items-start";
const sectionLabel =
  "dark:text-white text-base-900 font-medium tracking-tighter lg:max-w-full";
const sectionContent = "lg:col-span-3 min-w-0 w-full";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24 lg:py-48">
      <nav aria-label="Ruta de navegació" class="mb-6">
        <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 list-none p-0 m-0">
          <li>
            <Text tag="a" variant="textXS" href={withBase("/")} class={breadcrumbLink}>
              Inici
            </Text>
          </li>
          <li
            class="text-base-400 dark:text-base-600 uppercase text-xs select-none"
            aria-hidden="true"
          >
            /
          </li>
          <li>
            <Text
              tag="a"
              variant="textXS"
              href={itinerariHref}
              class={breadcrumbLink}
            >
              {itinerariTitle}
            </Text>
          </li>
          <li
            class="text-base-400 dark:text-base-600 uppercase text-xs select-none"
            aria-hidden="true"
          >
            /
          </li>
          <li>
            <Text
              tag="span"
              variant="textXS"
              class={breadcrumbCurrent}
              aria-current="page"
            >
              {frontmatter.title}
            </Text>
          </li>
        </ol>
      </nav>

      <Text
        tag="h1"
        variant="display3XL"
        class="dark:text-white text-base-900 font-medium tracking-tighter mb-8"
      >
        {frontmatter.title}
      </Text>

      <ParadaMedia media={frontmatter.media} />

      {
        frontmatter.videoAeri && (
          <div class="mt-8">
            <button
              type="button"
              data-video-modal-target={videoAeriModalId}
              class="group flex flex-wrap items-center gap-2 text-left cursor-pointer"
              aria-haspopup="dialog"
              aria-label={`Obrir: ${frontmatter.videoAeri.modalLabel ?? "Vista aèria de la parada"}`}
            >
              <Text
                tag="span"
                variant="displayMD"
                class="font-medium tracking-tighter text-accent-700 dark:text-accent-400 underline decoration-accent-700/30 dark:decoration-accent-400/40 underline-offset-[6px] group-hover:decoration-accent-700 dark:group-hover:decoration-accent-400 transition-colors leading-tight capitalize"
              >
                {frontmatter.videoAeri.modalLabel ?? "Vista aèria de la parada"}
              </Text>
              <span
                class="inline-flex size-7 shrink-0 items-center justify-center rounded-full border border-accent-700/25 dark:border-accent-400/30 text-accent-700 dark:text-accent-400 text-sm leading-none group-hover:bg-accent-700/10 dark:group-hover:bg-accent-400/10 transition-colors"
                aria-hidden="true"
              >
                ▶
              </span>
            </button>
          </div>
        )
      }

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "mt-8 border-t border-base-200 dark:border-base-800 pt-8"]}
      >
        <Text tag="h2" variant="displayMD" class={sectionLabel}>
          Coordenades
        </Text>
        <div class={sectionContent}>
          <Text
            tag="p"
            variant="textXL"
            class="text-base-500 dark:text-base-400 font-mono break-words"
          >
            {frontmatter.coordenades}
          </Text>
        </div>
      </div>
    </Wrapper>

    <Wrapper variant="standard" class="py-8 border-t border-base-200 dark:border-base-800">
      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "mb-12"]}
      >
        <Text tag="h2" variant="displayMD" class={sectionLabel}>
          Alflorament
        </Text>
        <div class={sectionContent}>
          <ParadaGallery fotos={frontmatter.fotos} galleryId={slug} />
        </div>
      </div>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "mb-12 border-t border-base-200 dark:border-base-800 pt-8"]}
      >
        <Text tag="h2" variant="displayMD" class={sectionLabel}>
          Mapa
        </Text>
        <div class={sectionContent}>
          <Text
            tag="a"
            variant="textXL"
            href={frontmatter.mapaUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent-600 dark:text-accent-400 hover:underline break-all"
          >
            {frontmatter.mapaUrl}
          </Text>
        </div>
      </div>

      {
        frontmatter.materials.length > 0 && (
          <div
            data-aos="fade-up"
            data-aos-duration="1000"
            class:list={[sectionGrid, "mb-12 border-t border-base-200 dark:border-base-800 pt-8"]}
          >
            <Text tag="h2" variant="displayMD" class={sectionLabel}>
              Materials
            </Text>
            <ul class:list={[sectionContent, "flex flex-col gap-3"]}>
              {frontmatter.materials.map((material) => (
                <li class="border-b border-base-200 dark:border-base-800 pb-3">
                  <Text
                    tag="a"
                    variant="textXL"
                    href={withBase(material.enllaç)}
                    class="text-base-900 dark:text-white hover:text-accent-600 dark:hover:text-accent-400"
                  >
                    {material.nom} →
                  </Text>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "mb-12 border-t border-base-200 dark:border-base-800 pt-8"]}
      >
        {
          frontmatter.geologia ? (
            <>
              <button
                type="button"
                data-modal-target={geologiaModalId}
                class="text-left cursor-pointer group inline-flex items-start gap-2"
                aria-haspopup="dialog"
                aria-label="Obrir geologia"
              >
                <Text
                  tag="span"
                  variant="displayMD"
                  class="font-medium tracking-tighter text-accent-700 dark:text-accent-400 underline decoration-accent-700/30 dark:decoration-accent-400/40 underline-offset-[6px] group-hover:decoration-accent-700 dark:group-hover:decoration-accent-400 transition-colors"
                >
                  Geologia
                </Text>
                <span
                  class="inline-flex size-7 shrink-0 items-center justify-center rounded-full border border-accent-700/25 dark:border-accent-400/30 text-accent-700 dark:text-accent-400 text-sm leading-none group-hover:bg-accent-700/10 dark:group-hover:bg-accent-400/10 transition-colors mt-0.5"
                  aria-hidden="true"
                >
                  +
                </span>
              </button>
              <Text
                tag="p"
                variant="textXL"
                class:list={[sectionContent, "text-base-500 dark:text-base-400"]}
              >
                {frontmatter.geologia.resum ?? frontmatter.title}
              </Text>
              <ItinerariDadaModal
                modalId={geologiaModalId}
                label={`Geologia — ${frontmatter.title}`}
                intro={frontmatter.geologia.intro}
                sections={frontmatter.geologia.sections ?? []}
              />
            </>
          ) : (
            <>
              <Text tag="h2" variant="displayMD" class={sectionLabel}>
                Geologia
              </Text>
              <Wrapper variant="prose" class:list={[sectionContent, "-mt-2"]}>
                <slot />
              </Wrapper>
            </>
          )
        }
      </div>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "border-t border-base-200 dark:border-base-800 pt-8"]}
      >
        {
          frontmatter.analisiFlora ? (
            <>
              <button
                type="button"
                data-modal-target={analisiFloraModalId}
                class="text-left cursor-pointer group inline-flex items-start gap-2"
                aria-haspopup="dialog"
                aria-label="Obrir geobotànica"
              >
                <Text
                  tag="span"
                  variant="displayMD"
                  class="font-medium tracking-tighter text-accent-700 dark:text-accent-400 underline decoration-accent-700/30 dark:decoration-accent-400/40 underline-offset-[6px] group-hover:decoration-accent-700 dark:group-hover:decoration-accent-400 transition-colors"
                >
                  Geobotànica
                </Text>
                <span
                  class="inline-flex size-7 shrink-0 items-center justify-center rounded-full border border-accent-700/25 dark:border-accent-400/30 text-accent-700 dark:text-accent-400 text-sm leading-none group-hover:bg-accent-700/10 dark:group-hover:bg-accent-400/10 transition-colors mt-0.5"
                  aria-hidden="true"
                >
                  +
                </span>
              </button>
              <Text
                tag="p"
                variant="textXL"
                class:list={[sectionContent, "text-base-500 dark:text-base-400"]}
              >
                {frontmatter.analisiFlora.resum ??
                  frontmatter.analisiFlora.nomCodi}
              </Text>
              <ParadaAnalisiFloraModal
                modalId={analisiFloraModalId}
                data={frontmatter.analisiFlora}
              />
            </>
          ) : (
            <>
              <Text tag="h2" variant="displayMD" class={sectionLabel}>
                Geobotànica
              </Text>
              <div class={sectionContent}>
                {
                  frontmatter.paisatgeUrl ? (
                    <Text
                      tag="a"
                      variant="textXL"
                      href={withBase(frontmatter.paisatgeUrl)}
                      class="inline-flex items-center gap-2 text-accent-600 dark:text-accent-400 hover:underline"
                    >
                      Veure l'anàlisi botànica i del paisatge →
                    </Text>
                  ) : (
                    <Text
                      tag="p"
                      variant="textXL"
                      class="text-base-500 dark:text-base-400"
                    >
                      Contingut en preparació.
                    </Text>
                  )
                }
              </div>
            </>
          )
        }
      </div>
    </Wrapper>

    {
      frontmatter.videoAeri && (
        <ItinerariVideoModal
          modalId={videoAeriModalId}
          label={frontmatter.videoAeri.modalLabel ?? "Vista aèria de la parada"}
          src={frontmatter.videoAeri.publicSrc}
          title={frontmatter.videoAeri.alt}
          sound={frontmatter.videoAeri.ambSo ?? true}
          allowFullscreen
        />
      )
    }
  </section>
</BaseLayout>
