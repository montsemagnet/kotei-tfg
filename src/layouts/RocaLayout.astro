---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import RocaGallery from "@/components/roques/RocaGallery.astro";

const { frontmatter, slug } = Astro.props;

const sectionGrid =
  "grid grid-cols-1 lg:grid-cols-4 gap-3 lg:gap-8 items-start";
const sectionLabel =
  "dark:text-white text-base-900 font-medium tracking-tighter lg:max-w-full";
const sectionContent = "lg:col-span-3 min-w-0 w-full";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24 lg:py-48">
      <Text
        tag="a"
        variant="textXS"
        href={`/parades/${frontmatter.parada}`}
        class="uppercase text-base-500 hover:text-base-900 dark:hover:text-white mb-6 inline-block"
      >
        ← Tornar a la parada
      </Text>

      <Text
        tag="h1"
        variant="display3XL"
        data-aos="fade-up"
        data-aos-duration="1000"
        class="dark:text-white text-base-900 font-medium tracking-tighter mb-12"
      >
        {frontmatter.title}
      </Text>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "border-t border-base-200 dark:border-base-800 pt-8 mb-8"]}
      >
        <Text tag="h4" variant="displayMD" class={sectionLabel}>
          Composició química
        </Text>
        <div class={sectionContent}>
          <Text tag="p" variant="textXL" class="text-base-500 dark:text-base-400">
            {frontmatter.composicioQuimica}
          </Text>
        </div>
      </div>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "border-t border-base-200 dark:border-base-800 pt-8 mb-8"]}
      >
        <Text tag="h4" variant="displayMD" class={sectionLabel}>
          Composició mineralògica
        </Text>
        <div class={sectionContent}>
          <Text tag="p" variant="textXL" class="text-base-500 dark:text-base-400">
            {frontmatter.composicioMineralogica}
          </Text>
        </div>
      </div>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "border-t border-base-200 dark:border-base-800 pt-8 mb-8"]}
      >
        <Text tag="h4" variant="displayMD" class={sectionLabel}>
          Textura
        </Text>
        <div class={sectionContent}>
          <Text tag="p" variant="textXL" class="text-base-500 dark:text-base-400">
            {frontmatter.textura}
          </Text>
        </div>
      </div>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class="border-t border-base-200 dark:border-base-800 pt-8 mb-8"
      >
        <Text tag="h4" variant="displayMD" class:list={[sectionLabel, "mb-6"]}>
          Imatges
        </Text>
        <RocaGallery
          optica={frontmatter.imatges.optica}
          fileres={frontmatter.imatges.fileres}
          galleryId={slug}
        />
      </div>
    </Wrapper>

    <Wrapper variant="standard" class="py-8 border-t border-base-200 dark:border-base-800">
      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "mb-12"]}
      >
        <Text tag="h4" variant="displayMD" class={sectionLabel}>
          Composicions
        </Text>
        <div class:list={[sectionContent, "overflow-x-auto"]}>
          <table class="w-full min-w-[320px] border-collapse text-left">
            <thead>
              <tr class="border-b border-base-200 dark:border-base-800">
                <th
                  class="py-3 pr-4 text-sm font-medium text-base-900 dark:text-white uppercase tracking-wide"
                >
                  Component
                </th>
                <th
                  class="py-3 text-sm font-medium text-base-900 dark:text-white uppercase tracking-wide"
                >
                  Valor
                </th>
              </tr>
            </thead>
            <tbody>
              {
                frontmatter.composicions.map((fila) => (
                  <tr class="border-b border-base-200 dark:border-base-800">
                    <td class="py-3 pr-4 text-base text-base-900 dark:text-white">
                      {fila.nom}
                    </td>
                    <td class="py-3 text-base text-base-500 dark:text-base-400 font-mono">
                      {fila.valor}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "border-t border-base-200 dark:border-base-800 pt-8"]}
      >
        <Text tag="h4" variant="displayMD" class={sectionLabel}>
          Observacions
        </Text>
        <Wrapper variant="prose" class:list={[sectionContent, "-mt-2"]}>
          <slot />
        </Wrapper>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
