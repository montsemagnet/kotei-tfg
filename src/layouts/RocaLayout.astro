---
import { getEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import RocaGallery from "@/components/roques/RocaGallery.astro";
import { findParadaBySlug } from "@/utils/paradaSlug";
import { withBase } from "@/utils/withBase";

const { frontmatter, slug } = Astro.props;

const paradaEntry = await findParadaBySlug(frontmatter.parada);
const paradaTitle = paradaEntry?.data.title ?? frontmatter.parada;
const paradaHref = withBase(`/parades/${frontmatter.parada}`);

const itinerariSlug = paradaEntry?.data.itinerari;
const itinerariEntry = itinerariSlug
  ? await getEntry("itineraris", itinerariSlug)
  : undefined;
const itinerariTitle = itinerariEntry?.data.title ?? "Itinerari";
const itinerariHref = itinerariSlug
  ? withBase(`/itineraris/${itinerariSlug}`)
  : withBase("/itineraris");

const breadcrumbLink =
  "uppercase text-base-500 hover:text-base-900 dark:hover:text-white transition-colors";
const breadcrumbCurrent =
  "uppercase text-base-900 dark:text-white font-medium";
const breadcrumbSeparator =
  "text-base-400 dark:text-base-600 uppercase text-xs select-none";

const sectionGrid =
  "grid grid-cols-1 lg:grid-cols-4 gap-3 lg:gap-8 items-start";
const sectionLabel =
  "dark:text-white text-base-900 font-medium tracking-tighter lg:max-w-full";
const sectionContent = "lg:col-span-3 min-w-0 w-full";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24 lg:py-48">
      <nav aria-label="Ruta de navegació" class="mb-6">
        <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 list-none p-0 m-0">
          <li>
            <Text tag="a" variant="textXS" href={withBase("/")} class={breadcrumbLink}>
              Inici
            </Text>
          </li>
          <li class={breadcrumbSeparator} aria-hidden="true">
            /
          </li>
          <li>
            <Text
              tag="a"
              variant="textXS"
              href={itinerariHref}
              class={breadcrumbLink}
            >
              {itinerariTitle}
            </Text>
          </li>
          <li class={breadcrumbSeparator} aria-hidden="true">
            /
          </li>
          <li>
            <Text
              tag="a"
              variant="textXS"
              href={paradaHref}
              class={breadcrumbLink}
            >
              {paradaTitle}
            </Text>
          </li>
          <li class={breadcrumbSeparator} aria-hidden="true">
            /
          </li>
          <li>
            <Text
              tag="span"
              variant="textXS"
              class={breadcrumbCurrent}
              aria-current="page"
            >
              {frontmatter.title}
            </Text>
          </li>
        </ol>
      </nav>

      <Text
        tag="h1"
        variant="display3XL"
        data-aos="fade-up"
        data-aos-duration="1000"
        class="dark:text-white text-base-900 font-medium tracking-tighter mb-12"
      >
        {frontmatter.title}
      </Text>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "border-t border-base-200 dark:border-base-800 pt-8 mb-8"]}
      >
        <Text tag="h2" variant="displayMD" class={sectionLabel}>
          Composició química
        </Text>
        <div class={sectionContent}>
          <Text tag="p" variant="textXL" class="text-base-500 dark:text-base-400">
            {frontmatter.composicioQuimica}
          </Text>
        </div>
      </div>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "border-t border-base-200 dark:border-base-800 pt-8 mb-8"]}
      >
        <Text tag="h2" variant="displayMD" class={sectionLabel}>
          Composició mineralògica
        </Text>
        <div class={sectionContent}>
          <Text tag="p" variant="textXL" class="text-base-500 dark:text-base-400">
            {frontmatter.composicioMineralogica}
          </Text>
        </div>
      </div>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "border-t border-base-200 dark:border-base-800 pt-8 mb-8"]}
      >
        <Text tag="h2" variant="displayMD" class={sectionLabel}>
          Textura
        </Text>
        <div class={sectionContent}>
          <Text tag="p" variant="textXL" class="text-base-500 dark:text-base-400">
            {frontmatter.textura}
          </Text>
        </div>
      </div>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class="border-t border-base-200 dark:border-base-800 pt-8 mb-8"
      >
        <Text tag="h2" variant="displayMD" class:list={[sectionLabel, "mb-6"]}>
          Imatges
        </Text>
        <RocaGallery
          optica={frontmatter.imatges.optica}
          fileres={frontmatter.imatges.fileres}
          galleryId={slug}
        />
      </div>
    </Wrapper>

    <Wrapper variant="standard" class="py-8 border-t border-base-200 dark:border-base-800">
      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "mb-12"]}
      >
        <Text tag="h2" variant="displayMD" class={sectionLabel}>
          Composicions
        </Text>
        <div class:list={[sectionContent, "overflow-x-auto"]}>
          <table class="w-full min-w-[320px] border-collapse text-left">
            <thead>
              <tr class="border-b border-base-200 dark:border-base-800">
                <th
                  class="py-3 pr-4 text-sm font-medium text-base-900 dark:text-white uppercase tracking-wide"
                >
                  Component
                </th>
                <th
                  class="py-3 text-sm font-medium text-base-900 dark:text-white uppercase tracking-wide"
                >
                  Valor
                </th>
              </tr>
            </thead>
            <tbody>
              {
                frontmatter.composicions.map((fila) => (
                  <tr class="border-b border-base-200 dark:border-base-800">
                    <td class="py-3 pr-4 text-base text-base-900 dark:text-white">
                      {fila.nom}
                    </td>
                    <td class="py-3 text-base text-base-500 dark:text-base-400 font-mono">
                      {fila.valor}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class:list={[sectionGrid, "border-t border-base-200 dark:border-base-800 pt-8"]}
      >
        <Text tag="h2" variant="displayMD" class={sectionLabel}>
          Observacions
        </Text>
        <Wrapper variant="prose" class:list={[sectionContent, "-mt-2"]}>
          <slot />
        </Wrapper>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
