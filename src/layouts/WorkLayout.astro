---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const { frontmatter } = Astro.props;
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24 lg:py-48">
      <Text tag="h1" variant="display5XL" data-aos="fade-up" data-aos-duration="1000" class="dark:text-white text-base-900 font-medium tracking-tighter mb-8">
        {frontmatter.title}
      </Text>

      <div data-aos="fade-up" data-aos-duration="1000" class="relative overflow-hidden">
        <Image width={1000} height={500} src={frontmatter.thumbnail.url} alt={frontmatter.thumbnail.alt} class="w-full object-cover" />
      </div>
    </Wrapper>

    <Wrapper variant="standard" class="py-8">
      
      {/* Intro */}
      <div data-aos="fade-up" data-aos-duration="1000" class="grid grid-cols-1 lg:grid-cols-4 gap-2 mb-12">
        <Text tag="h4" variant="displayXL" class="dark:text-white text-base-900 font-medium tracking-tighter">intro</Text>
        <div class="lg:col-span-3">
          {frontmatter.intro.map((item) => (
             item.paragraphs.map((p) => <Text tag="p" variant="displayMD" class="dark:text-white text-black mb-4">{p}</Text>)
          ))}
        </div>
      </div>

      {/* Dades */}
      <div class="flex flex-col border-t border-base-200 dark:border-base-800 mb-12">
        {frontmatter.projectData.map((credit) => (
          Object.entries(credit).map(([key, value]) => (
            <div data-aos="fade-up" data-aos-duration="1000" class="grid grid-cols-1 lg:grid-cols-4 items-baseline gap-2 py-4 border-b border-base-200 dark:border-base-800">
              <Text tag="h4" variant="displayXL" class="dark:text-white text-base-900 font-medium tracking-tighter capitalize">
                 {key === 'client' ? 'ubicació' : key === 'service' ? 'mapa' : key === 'sector' ? 'sòcol' : key === 'year' ? 'historia' : key}
              </Text>
              <Text tag="p" variant="textXL" class="text-base-500 dark:text-base-400 lg:col-span-3">{value}</Text>
            </div>
          ))
        ))}
      </div>

      {/* Galeria */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-2 mb-12">
        {frontmatter.images.map((image) => (
          <div data-aos="fade-up" data-aos-duration="1000">
            <Image src={image.url} alt={image.alt} width={600} height={600} class="w-full h-full object-cover" />
          </div>
        ))}
      </div>

      {/* Credits */}
      <div data-aos="fade-up" data-aos-duration="1000" class="grid grid-cols-1 lg:grid-cols-4 gap-2 mt-12">
        <Text tag="h4" variant="displayXL" class="dark:text-white text-base-900 font-medium tracking-tighter">Credits</Text>
        <div class="lg:col-span-3 flex flex-col gap-4">
          {frontmatter.credits.map((credit) => (
            <div class="flex justify-between border-b border-base-200 dark:border-base-800 py-4">
              <Text tag="p" variant="displaySM" class="dark:text-white font-medium">{credit.name}</Text>
              <Text tag="p" variant="textXL" class="text-base-500 dark:text-base-400">{credit.role}</Text>
            </div>
          ))}
        </div>
      </div>

    </Wrapper>
  </section>
</BaseLayout>