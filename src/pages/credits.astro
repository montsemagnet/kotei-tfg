---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import CreditsDetailModal from "@/components/credits/CreditsDetailModal.astro";
import CreditsModalTrigger from "@/components/credits/CreditsModalTrigger.astro";
import {
  project,
  teamMembers,
  thirdPartyResources,
  thirdPartyResourceGroups,
  paleogeologiaVideoCredits,
  paleogeologiaVideoCreditGroups,
} from "@/data/project";

const lastUpdated = new Date().toLocaleDateString("ca-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const apaCitation = `Magnet Sabata, M. (${project.publicationYear}). ${project.title}: ${project.subtitle}. ${project.institution}. ${Astro.site}`;

const thirdPartyModalId = "credits-third-party-modal";
const paleogeologiaModalId = "credits-paleogeologia-modal";

const thirdPartyIntro =
  "Programari, plantilla, tipografies, icones i serveis utilitzats per al lloc web en general.";

const paleogeologiaIntro =
  "Els tres vídeos de paleogeologia han estat elaborats per Montserrat Magnet Sabata. A continuació es detallen les fonts, dades, programari i música de tercers utilitzades en la seva producció; la selecció de continguts, el muntatge, l'edició i l'adaptació dels materials són obra de l'autora. Les dades d'EarthByte Group estan subjectes a la llicència Creative Commons Attribution 3.0 Unported (CC BY 3.0).";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24 lg:py-32 max-w-3xl">
      <Text
        tag="h1"
        variant="displayXL"
        class="dark:text-white text-base-900 font-medium tracking-tighter"
      >
        Crèdits i llicències
      </Text>
      <Text
        tag="p"
        variant="textBase"
        class="mt-2 text-base-500 dark:text-base-400"
      >
        Darrera actualització: {lastUpdated}
      </Text>

      <div class="mt-12 space-y-12 text-base md:text-lg leading-relaxed text-base-700 dark:text-base-300">
        <section>
          <Text
            tag="h2"
            variant="textLG"
            class="font-medium text-base-900 dark:text-white"
          >
            Identificació del recurs
          </Text>
          <dl class="mt-4 space-y-2">
            <div>
              <dt class="font-medium text-base-900 dark:text-white">Títol</dt>
              <dd>{project.title}</dd>
            </div>
            <div>
              <dt class="font-medium text-base-900 dark:text-white">
                Descripció
              </dt>
              <dd>{project.subtitle}</dd>
            </div>
            <div>
              <dt class="font-medium text-base-900 dark:text-white">
                Institució
              </dt>
              <dd>{project.institution}</dd>
            </div>
            <div>
              <dt class="font-medium text-base-900 dark:text-white">
                Facultat
              </dt>
              <dd>{project.faculty}</dd>
            </div>
            <div>
              <dt class="font-medium text-base-900 dark:text-white">Any</dt>
              <dd>{project.publicationYear}</dd>
            </div>
          </dl>
        </section>

        <section>
          <Text
            tag="h2"
            variant="textLG"
            class="font-medium text-base-900 dark:text-white"
          >
            Autoria i rols
          </Text>
          <ul class="mt-4 space-y-6">
            {
              teamMembers.map((member) => (
                <li>
                  <Text
                    tag="p"
                    variant="textBase"
                    class="font-medium text-base-900 dark:text-white"
                  >
                    {member.name}
                  </Text>
                  <Text tag="p" variant="textBase" class="mt-1">
                    {member.roles.join(" · ")}
                  </Text>
                  {member.bio && (
                    <Text tag="p" variant="textBase" class="mt-1 text-base-500">
                      {member.bio}
                    </Text>
                  )}
                  {
                    member.qualifications && (
                      <ul class="mt-2 space-y-1 text-base-500">
                        {
                          member.qualifications.map((item) => (
                            <li>{item}</li>
                          ))
                        }
                      </ul>
                    )
                  }
                  <a
                    href={`mailto:${member.email}`}
                    class="mt-1 inline-block hover:text-accent-500 dark:hover:text-accent-300 duration-300"
                  >
                    {member.email}
                  </a>
                  {
                    member.profileUrl && (
                      <Text tag="p" variant="textBase" class="mt-1">
                        <a
                          href={member.profileUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="hover:text-accent-500 dark:hover:text-accent-300 duration-300"
                        >
                          Perfil a la FCTE
                        </a>
                      </Text>
                    )
                  }
                </li>
              ))
            }
          </ul>
        </section>

        <section>
          <Text
            tag="h2"
            variant="textLG"
            class="font-medium text-base-900 dark:text-white"
          >
            Drets d'autor i reutilització
          </Text>
          <Text tag="p" variant="textBase" class="mt-4 leading-relaxed">
            © {project.publicationYear} Montserrat Magnet Sabata. Treball de
            Final de Grau — Grau en Biologia. Tots els drets reservats.
          </Text>
          <Text tag="p" variant="textBase" class="mt-3 leading-relaxed">
            El contingut científic d'aquest lloc (textos, imatges de camp,
            dades geològiques, materials petrogràfics, mapes i recursos
            didàctics) és propietat de l'autora i les seves tutores, llevat que
            s'indiqui el contrari. Està prohibit reproduir, distribuir,
            modificar o publicar qualsevol part d'aquest recurs, en qualsevol
            format, sense autorització expressa i per escrit de l'autora i les
            tutores acadèmiques.
          </Text>
          <Text tag="p" variant="textBase" class="mt-3 leading-relaxed">
            El codi font de la plataforma web forma part del treball de final
            de grau i queda subjecte a les mateixes condicions, llevat d'un
            acord escrit en contrari amb la facultat.
          </Text>
        </section>

        <section>
          <Text
            tag="h2"
            variant="textLG"
            class="font-medium text-base-900 dark:text-white"
          >
            Contacte institucional
          </Text>
          <Text tag="p" variant="textBase" class="mt-4">
            Facultat de Ciències, Tecnologia i Enginyeries (FCTE):
            <a
              href={`mailto:${project.facultyContact}`}
              class="ml-1 hover:text-accent-500 dark:hover:text-accent-300 duration-300"
            >
              {project.facultyContact}
            </a>
          </Text>
        </section>

        <section>
          <Text
            tag="h2"
            variant="textLG"
            class="font-medium text-base-900 dark:text-white"
          >
            Com citar aquest recurs (APA 7)
          </Text>
          <blockquote
            class="mt-4 border-l-2 border-base-300 dark:border-base-600 pl-4 leading-relaxed italic"
          >
            {apaCitation}
          </blockquote>
        </section>

        <section>
          <Text
            tag="h2"
            variant="textLG"
            class="font-medium text-base-900 dark:text-white"
          >
            Fonts i recursos de tercers
          </Text>
          <div
            class="mt-4 flex flex-col border-t border-base-200 dark:border-base-800"
          >
            <div class="py-4 border-b border-base-200 dark:border-base-800 space-y-2">
              <CreditsModalTrigger
                modalId={thirdPartyModalId}
                label="Recursos de tercers (plataforma web)"
              />
              <Text
                tag="p"
                variant="textBase"
                class="text-base-500 dark:text-base-400"
              >
                {thirdPartyIntro}
              </Text>
            </div>

            {
              paleogeologiaVideoCredits.length > 0 && (
                <div class="py-4 border-b border-base-200 dark:border-base-800 space-y-2">
                  <CreditsModalTrigger
                    modalId={paleogeologiaModalId}
                    label="Vídeos de paleogeologia (Sau–Tavertet)"
                  />
                  <Text
                    tag="p"
                    variant="textBase"
                    class="text-base-500 dark:text-base-400"
                  >
                    Vídeos elaborats per l'autora amb fonts, dades, programari
                    i música de tercers.
                  </Text>
                </div>
              )
            }
          </div>
        </section>
      </div>
    </Wrapper>
  </section>

  <CreditsDetailModal
    modalId={thirdPartyModalId}
    label="Recursos de tercers (plataforma web)"
    intro={thirdPartyIntro}
  >
    <div class="space-y-8">
      {
        thirdPartyResourceGroups.map((group) => {
          const items = thirdPartyResources.filter(
            (resource) => resource.category === group.id,
          );
          if (items.length === 0) return null;
          return (
            <div>
              <Text
                tag="h3"
                variant="textBase"
                class="font-medium text-base-900 dark:text-white"
              >
                {group.title}
              </Text>
              <ul class="mt-3 space-y-3">
                {
                  items.map((resource) => (
                    <li class="min-w-0 break-words">
                      <span class="font-medium text-base-900 dark:text-white">
                        {resource.name}
                      </span>
                      {" — "}
                      {resource.use}.{" "}
                      <a
                        href={resource.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="break-all hover:text-accent-500 dark:hover:text-accent-300 duration-300"
                      >
                        {resource.url}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          );
        })
      }
    </div>
    <Text tag="p" variant="textBase" class="mt-6 leading-relaxed">
      El servei de traducció automàtica (Google Translate) pot generar errors
      en terminologia científica. En cas de discrepància, preval el text en
      català.
    </Text>
  </CreditsDetailModal>

  {
    paleogeologiaVideoCredits.length > 0 && (
      <CreditsDetailModal
        modalId={paleogeologiaModalId}
        label="Vídeos de paleogeologia (itinerari Sau–Tavertet)"
        intro={paleogeologiaIntro}
      >
        <div class="space-y-10">
          {
            paleogeologiaVideoCreditGroups.map((group) => {
              const items = paleogeologiaVideoCredits.filter(
                (resource) => resource.category === group.id,
              );
              if (items.length === 0) return null;
              return (
                <div>
                  <Text
                    tag="h3"
                    variant="textBase"
                    class="font-medium text-base-900 dark:text-white"
                  >
                    {group.title}
                  </Text>
                  <ul class="mt-4 space-y-8">
                    {
                      items.map((resource) => (
                        <li class="min-w-0 break-words">
                          <Text
                            tag="p"
                            variant="textBase"
                            class="font-medium text-base-900 dark:text-white break-words"
                          >
                            {resource.label}
                          </Text>
                          <Text tag="p" variant="textBase" class="mt-1 break-words">
                            {resource.use}
                            {resource.license && (
                              <>
                                {" "}
                                <span class="text-base-500 dark:text-base-400">
                                  — Llicència: {resource.license}
                                </span>
                              </>
                            )}
                          </Text>
                          {
                            resource.url && (
                              <Text tag="p" variant="textBase" class="mt-1 break-all">
                                <a
                                  href={resource.url}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  class="break-all hover:text-accent-500 dark:hover:text-accent-300 duration-300"
                                >
                                  {resource.url}
                                </a>
                              </Text>
                            )
                          }
                          <blockquote
                            class="mt-3 border-l-2 border-base-300 dark:border-base-600 pl-4 leading-relaxed italic text-base-600 dark:text-base-400 break-words [overflow-wrap:anywhere]"
                          >
                            {resource.apaCitation}
                          </blockquote>
                        </li>
                      ))
                    }
                  </ul>
                </div>
              );
            })
          }
        </div>
      </CreditsDetailModal>
    )
  }

  <script>
    import { bindDialogTrigger } from "@/utils/modalA11y";

    function initCreditsDetailModals() {
      document.querySelectorAll("[data-credits-modal-target]").forEach((btn) => {
        if (!(btn instanceof HTMLElement)) return;

        const modalId = btn.dataset.creditsModalTarget;
        if (!modalId) return;

        const dialog = document.getElementById(modalId);
        if (!(dialog instanceof HTMLDialogElement)) return;

        bindDialogTrigger(btn, dialog);
      });
    }

    initCreditsDetailModals();
    document.addEventListener("astro:after-swap", initCreditsDetailModals);
  </script>
</BaseLayout>
