---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Sections
import Hero from "@/components/landing/Hero.astro";
import Philosphy from "@/components/landing/Philosphy.astro";
import HowWeWork from "@/components/landing/HowWeWork.astro";
import Team from "@/components/landing/Team.astro";

// Components
import LogoCloud from "@/components/assets/LogoCloud.astro";
import ItinerariCard1 from "@/components/itinerari/ItinerariCard1.astro";
import GlossariSection from "@/components/global/GlossariSection.astro";
import { Image } from "astro:assets";
// Content
import { getCollection } from "astro:content";
import { withBase } from "@/utils/withBase";
const allItineraris = (await getCollection("itineraris"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => (a.data.ordre ?? 999) - (b.data.ordre ?? 999));

const featuredItinerari = allItineraris.find(
  (entry) => entry.id === "sau-tavertet" && !(entry.data.enConstruccio ?? false),
);
---

<BaseLayout>
  <Hero />
  <LogoCloud />
  <Philosphy />

  <section>
    <Wrapper variant="standard" class="pb-12">
      {
        featuredItinerari && (
          <>
            <div class="featured-itinerari w-full max-w-full">
              <div class="featured-itinerari__row flex flex-col gap-5 sm:flex-row sm:items-stretch sm:gap-6 lg:gap-8">
                <div class="featured-itinerari__heading relative z-10 shrink-0 sm:min-w-[10rem] lg:min-w-[10.5rem]">
                  <Text
                    tag="h2"
                    variant="displayXL"
                    data-aos="fade-up"
                    data-aos-duration="1000"
                    class="dark:text-white text-base-900 font-medium tracking-tighter"
                  >
                    Itinerari
                    <br />
                    destacat
                  </Text>
                </div>

                <a
                  href={withBase(`/itineraris/${featuredItinerari.id}`)}
                  title={featuredItinerari.data.title}
                  class="featured-itinerari__photo relative z-0 min-h-[4.5rem] min-w-0 flex-1 overflow-hidden"
                  data-aos="fade-up"
                  data-aos-duration="1000"
                  data-aos-delay="100"
                >
                  <Image
                    src={featuredItinerari.data.thumbnail.url}
                    alt={featuredItinerari.data.title}
                    width={1200}
                    height={288}
                    class="size-full min-h-[4.5rem] object-cover object-[58%_50%] max-sm:aspect-[3/1] max-sm:object-[65%_center]"
                  />
                </a>

                <div class="featured-itinerari__copy shrink-0 sm:w-[11.75rem] md:w-[13rem] lg:w-[14.25rem]">
                  <ItinerariCard1
                    post={featuredItinerari}
                    index={1}
                    variant="featured"
                    hideImage
                    subtitle="Itinerari geològic UVIC"
                  />
                </div>
              </div>
            </div>

            <div
              class="proximament-block mt-16 lg:mt-24 flex w-fit max-w-full flex-col gap-4 lg:flex-row lg:items-start lg:gap-8"
              data-aos="fade-up"
              data-aos-duration="1500"
            >
              <Text
                tag="h3"
                variant="displayXL"
                data-aos="fade-up"
                data-aos-duration="1500"
                class="shrink-0 dark:text-white text-base-900 font-medium tracking-tighter text-balance"
              >
                Pròximament
              </Text>
              <Text
                tag="p"
                variant="textBase"
                class="min-w-0 flex-1 text-pretty text-base-700 dark:text-base-400 leading-relaxed lg:text-justify"
              >
                Nous itineraris s'incorporaran progressivament per ampliar els àmbits
                geològics i els materials d'estudi disponibles
              </Text>
            </div>
          </>
        )
      }
    </Wrapper>
  </section>
  <HowWeWork />
  <Team />
  <section>
    <Wrapper variant="standard" class="pb-24 lg:pb-48">
      <GlossariSection showCartaPdf />
    </Wrapper>
  </section>
</BaseLayout>
