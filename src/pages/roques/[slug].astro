---
import { getCollection, render } from "astro:content";
import RocaLayout from "@/layouts/RocaLayout.astro";
import { getRocaSlug } from "@/utils/rocaSlug";

export async function getStaticPaths() {
  const roques = await getCollection("roques");
  return roques.map((entry) => {
    const slug = getRocaSlug(entry);
    return {
      params: { slug },
      props: { entry, slug },
    };
  });
}

const { entry, slug } = Astro.props;
const { Content } = await render(entry);
---

<RocaLayout frontmatter={entry.data} slug={slug}>
  <Content />
</RocaLayout>
